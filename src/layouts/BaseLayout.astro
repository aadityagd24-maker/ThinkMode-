---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
}

const { 
  title, 
  description, 
  canonicalPath = '',
  ogImage = '/logo.png'
} = Astro.props;

const siteUrl = 'https://thinkmodeplus.com';
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImageUrl = `${siteUrl}${ogImage}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonicalUrl}>

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImageUrl}>
  <meta property="og:site_name" content="ThinkMode+">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImageUrl}>

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/logo.png">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <ClientRouter />
  <slot name="head" />
</head>
<body>
  <div class="glow"></div>

  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <img src="/logo.png" alt="ThinkMode+ Logo" style="width: 28px; height: 28px; object-fit: contain;" />
        ThinkMode+
      </a>
      <div class="nav-links">
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms</a>
        <a href="/#features">Features</a>
        <a href="/#pricing">Pricing</a>
        <a href="/#faq">FAQ</a>
        <a href="/auth" class="nav-cta" id="nav-auth-btn">Sign in &rarr;</a>
      </div>
    </div>
  </nav>

  <div class="wrap">
    <slot />
  </div>

  <footer class="footer">
    <div class="wrap footer-inner">
      <div class="footer-logo">
        <img src="/logo.png" alt="ThinkMode+ Logo" style="width: 24px; height: 24px; object-fit: contain; filter: grayscale(1) opacity(0.7);" />
        ThinkMode+
      </div>
      <div class="footer-links">
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
        <a href="/support">Support</a>
        <a href="/changelog">Changelog</a>
      </div>
      <div class="footer-copy">&copy; 2026 ThinkMode+ &middot; Not affiliated with OpenAI</div>
    </div>
  </footer>

  <slot name="scripts" />

  <!-- Premium Coming Soon Modal -->
  <div id="coming-soon-modal" class="modal-overlay">
    <div class="premium-modal">
      <div class="shiny-sweep"></div>
      <div class="modal-close" id="close-modal">&times;</div>
      <div class="modal-icon">
        <div class="pulse-ring-modal"></div>
        <img src="/logo.png" alt="ThinkMode+ Logo" />
      </div>
      <h3>We're upgrading ThinkMode+</h3>
      <p>We're very sorry, Product under management, will be back in 2 days.</p>
      <div class="modal-signature">~ Founder- Aayush</div>
    </div>
  </div>

  <script>
    document.addEventListener('astro:page-load', async () => {
      // Handle Modal
      const modal = document.getElementById('coming-soon-modal');
      const closeBtn = document.getElementById('close-modal');
      const ctaLinks = document.querySelectorAll('a');
      
      ctaLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          const text = link.textContent?.toLowerCase() || '';
          if (text.includes('add to edge')) {
            e.preventDefault();
            modal?.classList.add('active');
          }
        });
      });

      closeBtn?.addEventListener('click', () => {
        modal?.classList.remove('active');
      });

      modal?.addEventListener('click', (e) => {
        if (e.target === modal) {
          modal.classList.remove('active');
        }
      });
    });
  </script>

  <script>
    import { supabase } from '../lib/supabase.js';

    document.addEventListener('astro:page-load', async () => {
      const authBtn = document.getElementById('nav-auth-btn');
      if (authBtn) {
        const { data: { session } } = await supabase.auth.getSession();
        if (session) {
          authBtn.textContent = 'Dashboard \u2192';
          authBtn.href = '/dashboard';
        }
      }
    });
  </script>
</body>
</html>
