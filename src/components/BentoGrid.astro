---
// BentoGrid.astro
---

<section class="section bento-section wrap" id="features">
  <div class="section-head text-center">
    <p class="section-eyebrow">// premium features</p>
    <h2>Bento Grid Showcase.</h2>
    <p>Everything you need to squeeze maximum performance out of the world's best AI models.</p>
  </div>
  
  <div class="bento-grid">
    <!-- Always-On Think Mode -->
    <div class="bento-card bento-large">
      <div class="bento-content">
        <h3>Always-On Think Mode</h3>
        <p>Never manually click "Think Harder" again. We force the deepest reasoning mode across all platforms.</p>
      </div>
      <div class="bento-visual always-on-visual">
        <div class="toggle-switch"></div>
      </div>
    </div>

    <!-- Expert Role Injection -->
    <div class="bento-card bento-tall">
      <div class="bento-content">
        <h3>Expert Role Injection</h3>
        <p>Instantly adopt professional personas.</p>
      </div>
      <div class="bento-visual role-visual">
        <span class="role-badge">Senior Dev</span>
        <span class="role-badge">Copywriter</span>
        <span class="role-badge">Data Analyst</span>
        <span class="role-badge">UX Designer</span>
        <span class="role-badge">Product Mgr</span>
        <span class="role-badge">SEO Expert</span>
        <span class="role-badge">Legal Advisor</span>
      </div>
    </div>

    <!-- Quick Follow-Up Bar -->
    <div class="bento-card">
      <div class="bento-content">
        <h3>Quick Follow-Up Bar</h3>
        <p>Rapid contextual actions.</p>
      </div>
      <div class="bento-visual follow-up-visual">
        <div class="action-btn">Explain</div>
        <div class="action-btn">Refactor</div>
      </div>
    </div>

    <!-- Format Forcing -->
    <div class="bento-card bento-wide">
      <div class="bento-content">
        <h3>Format Forcing</h3>
        <p>Ensure the output matches your exact structural needs: Table, Code, or Essay.</p>
      </div>
      <div class="bento-visual format-visual">
        <div class="format-option">Table</div>
        <div class="format-option active">Code</div>
        <div class="format-option">Essay</div>
      </div>
    </div>
  </div>
</section>

<style>
/* Scoped styles specific to Bento logic, though global.css handles layout */
</style>
