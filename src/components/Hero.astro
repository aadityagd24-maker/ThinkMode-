---
// Hero.astro
---

<header class="hero wrap">
  <div class="hero-content">
    <div class="eyebrow">
      <span class="pulse"></span>
      live on chrome &amp; edge
    </div>
    <h1>Supercharge your AI.<br><span class="grad-text">ThinkMode+</span></h1>
    <p class="lead">
      Always-on extended thinking, expert role injection, and format forcing for ChatGPT, Claude, and Gemini. Professional-grade outputs, every time.
    </p>
    <div class="hero-ctas">
      <a href="#" class="btn btn-primary">Add to Chrome — free</a>
      <a href="#features" class="btn btn-ghost">View Features</a>
    </div>
    <div class="hero-meta">
      <span>14-day free trial</span>
      <span>3 platforms, 1 toggle</span>
      <span>Zero prompt edits</span>
    </div>
  </div>

  <div class="hero-visual">
    <div class="sim-ui">
      <div class="sim-ui-header">
        <div class="traffic"><span></span><span></span><span></span></div>
        <div class="sim-tabs">
          <div class="sim-tab active" style="font-family: var(--mono); font-size: 12px; padding: 4px 10px;">ChatGPT</div>
          <div class="sim-tab" style="font-family: var(--mono); font-size: 12px; padding: 4px 10px;">Claude</div>
          <div class="sim-tab" style="font-family: var(--mono); font-size: 12px; padding: 4px 10px;">Gemini</div>
        </div>
      </div>
      <div class="sim-ui-body">
        <div class="sim-inject active-think">
          <div class="think-dots"><span></span><span></span><span></span></div>
          <span>Always-On Think Mode Enabled</span>
        </div>
        <div class="sim-inject">
          <div class="inject-label">Expert Role</div>
          <div class="inject-value">Senior Dev</div>
        </div>
        <div class="sim-inject">
          <div class="inject-label">Response Depth</div>
          <div class="inject-value">Comprehensive</div>
        </div>
      </div>
    </div>
  </div>
</header>
