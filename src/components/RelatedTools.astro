---
const tools = [
  {
    title: "Custom Instructions Generator",
    desc: "Instantly build the perfect expert persona for ChatGPT.",
    link: "/tools/custom-instructions-generator",
    icon: "🎭"
  },
  {
    title: "Prompt Optimizer",
    desc: "Turn weak instructions into highly effective prompts.",
    link: "/tools/prompt-optimizer",
    icon: "✨"
  },
  {
    title: "Text Splitter",
    desc: "Bypass character limits by chunking large documents safely.",
    link: "/tools/text-splitter",
    icon: "✂️"
  },
  {
    title: "Formatting Gallery",
    desc: "Templates for strict JSON, Tables, and code outputs.",
    link: "/tools/formatting-gallery",
    icon: "📊"
  },
  {
    title: "Fact Checker",
    desc: "Self-reflection prompts to stop AI hallucinations.",
    link: "/tools/hallucination-checker",
    icon: "🛡️"
  },
  {
    title: "Thinking Mode Guide",
    desc: "How to keep ChatGPT reasoning mode always on.",
    link: "/guide/chatgpt-thinking-mode",
    icon: "🧠"
  }
];

// Shuffle array to show random related tools
const shuffled = tools.sort(() => 0.5 - Math.random());
// Get 3 tools that don't match the current URL
const related = shuffled.filter(t => t.link !== Astro.url.pathname).slice(0, 3);
---

<div class="related-tools">
  <h3>Explore More Free Tools</h3>
  <div class="related-grid">
    {related.map(tool => (
      <a href={tool.link} class="related-card">
        <div class="related-icon">{tool.icon}</div>
        <div class="related-text">
          <h4>{tool.title}</h4>
          <p>{tool.desc}</p>
        </div>
      </a>
    ))}
  </div>
</div>

<style>
  .related-tools {
    margin: 64px 0 0;
    padding-top: 48px;
    border-top: 1px solid var(--border);
  }
  .related-tools h3 {
    font-size: 20px;
    font-weight: 600;
    margin: 0 0 24px;
    color: var(--text);
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 16px;
  }
  .related-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
  }
  .related-card:hover {
    background: var(--surface-2);
    border-color: var(--border-hi);
    transform: translateY(-2px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.1);
  }
  .related-icon {
    font-size: 24px;
    background: rgba(255,255,255,0.05);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    flex-shrink: 0;
  }
  .related-text h4 {
    margin: 0 0 6px;
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
  }
  .related-text p {
    margin: 0;
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.5;
  }
</style>
