---
// Pricing.astro
---

<section class="section wrap" id="pricing">
  <div class="section-head text-center">
    <p class="section-eyebrow">// pricing</p>
    <h2>Cheaper than your coffee.</h2>
    <p>Generous free tier with daily limits. Upgrade to unlock unlimited potential — no retention maze, no dark patterns.</p>
  </div>

  <div class="pricing-segment-control">
    <div class="segment-bg yearly-active" id="segment-bg"></div>
    <div class="segment-btn" id="label-monthly">Monthly</div>
    <div class="segment-btn active" id="label-yearly">
      Yearly <span class="discount-badge">Save up to 50%</span>
    </div>
    <div class="segment-btn" id="label-lifetime">Lifetime</div>
  </div>

  <div id="lifetime-headline" style="display:none; text-align:center; color:var(--accent); font-family:var(--mono); text-transform:uppercase; font-size:14px; margin-top:32px; font-weight:700; letter-spacing:1px;">
    Own Your Product
  </div>

  <div class="pricing-grid">
    <div class="price-card">
      <h3>Free</h3>
      <p>try the core loop</p>
      <div class="price">$0</div>
      <ul class="price-features">
        <li>auto-enable on 1 platform</li>
        <li>limited daily activations</li>
        <li>community support</li>
      </ul>
      <a href="#" class="btn btn-ghost" style="width:100%; justify-content:center;">Add to Chrome</a>
    </div>
    <div class="price-card featured">
      <div class="plan-tag-container yearly-only">
        <div class="tag-wrapper">
          <div class="plan-tag"><div class="tag-shine"></div>5 Months Free</div>
          <div class="thread"></div>
        </div>
        <div class="hole"></div>
      </div>
      <h3>Pro</h3>
      <p>one account, everywhere you think</p>
      <div class="price">
        <span class="price-currency">$</span><span class="price-amount" data-monthly="2.99" data-yearly="1.66" data-lifetime="69.99">1.66</span><span class="price-period">/mo</span>
      </div>
      <div class="price-sub yearly-only">Billed $19.99 yearly</div>
      <div class="price-sub monthly-only" style="display:none;">Billed $2.99 monthly</div>
      <div class="price-sub lifetime-only" style="display:none;">One-time payment</div>
      <ul class="price-features">
        <li>ChatGPT + Claude + Gemini</li>
        <li>unlimited activations</li>
        <li>per-platform on/off control</li>
        <li>priority support</li>
      </ul>
      <a href="#" class="btn btn-primary chrome-install-btn" style="width:100%; justify-content:center;">Buy Now</a>
    </div>
    <div class="price-card">
      <div class="plan-tag-container yearly-only">
        <div class="tag-wrapper">
          <div class="plan-tag"><div class="tag-shine"></div>6 Months Free</div>
          <div class="thread"></div>
        </div>
        <div class="hole"></div>
      </div>
      <h3>Power User</h3>
      <p>1 account, 3 browsers</p>
      <div class="price">
        <span class="price-currency">$</span><span class="price-amount" data-monthly="4.99" data-yearly="2.49" data-lifetime="99.99">2.49</span><span class="price-period">/mo</span>
      </div>
      <div class="price-sub yearly-only">Billed $29.99 yearly</div>
      <div class="price-sub monthly-only" style="display:none;">Billed $4.99 monthly</div>
      <div class="price-sub lifetime-only" style="display:none;">One-time payment</div>
      <ul class="price-features">
        <li>everything in Pro</li>
        <li>same account on 3 browsers</li>
        <li>built for power users</li>
      </ul>
      <a href="#" class="btn btn-ghost chrome-install-btn" style="width:100%; justify-content:center;">Buy Now</a>
    </div>
  </div>

  <div class="why-charge-container">
    <div class="heart-icon">
      <img src="/heart_3d.png" alt="Heart" width="48" height="48" style="object-fit: contain; filter: drop-shadow(0 4px 12px rgba(186, 58, 184, 0.4));" />
    </div>
    <div class="why-charge-box">
      <h4>Why we charge</h4>
      <p>AI tools like ChatGPT, Claude and Gemini change their code frequently. Your premium subscription supports our ongoing maintenance to keep everything working smoothly.</p>
    </div>
  </div>

  <div class="pricing-foot">// no card required to install</div>

  <script>
    document.addEventListener('astro:page-load', () => {
      const segmentBg = document.getElementById('segment-bg');
      const labelMonthly = document.getElementById('label-monthly');
      const labelYearly = document.getElementById('label-yearly');
      const labelLifetime = document.getElementById('label-lifetime');
      const lifetimeHeadline = document.getElementById('lifetime-headline');
      const amounts = document.querySelectorAll('.price-amount');
      const periods = document.querySelectorAll('.price-period');
      const yearlyElements = document.querySelectorAll('.yearly-only');
      const monthlyElements = document.querySelectorAll('.monthly-only');
      const lifetimeElements = document.querySelectorAll('.lifetime-only');
      let currentSegment = 'yearly';

      function updatePricing() {
        labelMonthly.classList.remove('active');
        labelYearly.classList.remove('active');
        labelLifetime.classList.remove('active');
        segmentBg.classList.remove('yearly-active', 'monthly-active', 'lifetime-active');

        if (currentSegment === 'yearly') {
          segmentBg.classList.add('yearly-active');
          labelYearly.classList.add('active');
          amounts.forEach(el => el.textContent = el.getAttribute('data-yearly'));
          periods.forEach(el => el.style.display = '');
          yearlyElements.forEach(el => el.style.display = '');
          monthlyElements.forEach(el => el.style.display = 'none');
          lifetimeElements.forEach(el => el.style.display = 'none');
          lifetimeHeadline.style.display = 'none';
        } else if (currentSegment === 'monthly') {
          segmentBg.classList.add('monthly-active');
          labelMonthly.classList.add('active');
          amounts.forEach(el => el.textContent = el.getAttribute('data-monthly'));
          periods.forEach(el => el.style.display = '');
          yearlyElements.forEach(el => el.style.display = 'none');
          monthlyElements.forEach(el => el.style.display = '');
          lifetimeElements.forEach(el => el.style.display = 'none');
          lifetimeHeadline.style.display = 'none';
        } else if (currentSegment === 'lifetime') {
          segmentBg.classList.add('lifetime-active');
          labelLifetime.classList.add('active');
          amounts.forEach(el => el.textContent = el.getAttribute('data-lifetime'));
          periods.forEach(el => el.style.display = 'none'); // Hide /mo
          yearlyElements.forEach(el => el.style.display = 'none');
          monthlyElements.forEach(el => el.style.display = 'none');
          lifetimeElements.forEach(el => el.style.display = '');
          lifetimeHeadline.style.display = 'block';
        }
      }

      labelMonthly.addEventListener('click', () => { currentSegment = 'monthly'; updatePricing(); });
      labelYearly.addEventListener('click', () => { currentSegment = 'yearly'; updatePricing(); });
      labelLifetime.addEventListener('click', () => { currentSegment = 'lifetime'; updatePricing(); });

      // Premium mouse tracking glow
      const cards = document.querySelectorAll('.price-card');
      cards.forEach(card => {
        card.addEventListener('mousemove', e => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          card.style.setProperty('--mouse-x', `${x}px`);
          card.style.setProperty('--mouse-y', `${y}px`);
        });
      });
    });
  </script>
</section>
