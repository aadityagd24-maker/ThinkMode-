---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolHero from '../../components/ToolHero.astro';
import BridgeCTA from '../../components/BridgeCTA.astro';
---

<BaseLayout
  title="Free AI Formatting Template Gallery: JSON, Markdown & More"
  description="Explore our free AI Formatting Template Gallery. Discover copy-and-paste ChatGPT prompts for developers to reliably generate JSON, Markdown tables, and structured outputs."
  canonicalPath="/tools/formatting-gallery"
>
  <Fragment slot="head">
    <meta name="keywords" content="ChatGPT output formatting, AI formatting templates, ChatGPT prompt templates for developers, ChatGPT JSON format generator, ChatGPT markdown table prompt, Structured output ChatGPT prompts">
    
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "ChatGPT Formatting Template Gallery",
      "url": "https://thinkmodeplus.com/tools/formatting-gallery",
      "description": "Gallery of ChatGPT prompt templates for structured output formatting.",
      "applicationCategory": "UtilityApplication"
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How do I force ChatGPT to output JSON?",
          "acceptedAnswer": { "@type": "Answer", "text": "Append our strict JSON template to your prompt. It explicitly tells the AI not to wrap the output in Markdown backticks or include conversational text." }
        },
        {
          "@type": "Question",
          "name": "Can I make ChatGPT write Markdown tables?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes, our Markdown Table prompt instructs ChatGPT to structure its output cleanly into columns and rows without preambles." }
        }
      ]
    })} />
  </Fragment>

  <div class="tool-page">
    <ToolHero 
      title="Free AI Formatting Template Gallery for Developers"
      subtitle="Copy these proven prompt snippets to force ChatGPT, Claude, and Gemini into strict output formats like JSON, Tables, and Code Blocks."
      breadcrumbToolName="Formatting Gallery"
      toolPath="/tools/formatting-gallery"
    />

    <!-- ARIA Live region for screen readers -->
    <div aria-live="polite" class="sr-only" id="sr-announcer"></div>

    <div class="gallery-grid">
      <!-- Template 1 -->
      <div class="format-card">
        <div class="format-header">
          <h2>📊 Markdown Table</h2>
          <button class="copy-btn" data-content="Format the output strictly as a Markdown table. Do not include any text before or after the table. Ensure the columns are properly aligned.">Copy</button>
        </div>
        <p class="format-desc">Force the AI to output a clean, organized table perfect for comparisons or data extraction.</p>
        <div class="format-code">Format the output strictly as a Markdown table. Do not include any text before or after the table. Ensure the columns are properly aligned.</div>
      </div>

      <!-- Template 2 -->
      <div class="format-card">
        <div class="format-header">
          <h2>⚙️ Strict JSON</h2>
          <button class="copy-btn" data-content="Output the response strictly in valid JSON format. Do not wrap the JSON in Markdown backticks. Do not include any explanatory text before or after the JSON.">Copy</button>
        </div>
        <p class="format-desc">Essential for developers building AI pipelines who need parseable data without conversational fluff.</p>
        <div class="format-code">Output the response strictly in valid JSON format. Do not wrap the JSON in Markdown backticks. Do not include any explanatory text before or after the JSON.</div>
      </div>

      <!-- Template 3 -->
      <div class="format-card">
        <div class="format-header">
          <h2>📝 Step-by-Step Guide</h2>
          <button class="copy-btn" data-content="Format the response as a numbered step-by-step guide. Use bold headers for each step. Provide a brief sentence explaining the expected outcome of each step.">Copy</button>
        </div>
        <p class="format-desc">Turns complex explanations into actionable, easy-to-follow tutorials.</p>
        <div class="format-code">Format the response as a numbered step-by-step guide. Use bold headers for each step. Provide a brief sentence explaining the expected outcome of each step.</div>
      </div>

      <!-- Template 4 -->
      <div class="format-card">
        <div class="format-header">
          <h2>💻 Code Block Only</h2>
          <button class="copy-btn" data-content="Provide only the raw code block. Do not include any conversational text, greetings, or explanations before or after the code.">Copy</button>
        </div>
        <p class="format-desc">Stops the AI from explaining the code when you just want a snippet to copy-paste into your editor.</p>
        <div class="format-code">Provide only the raw code block. Do not include any conversational text, greetings, or explanations before or after the code.</div>
      </div>
    </div>

    <BridgeCTA 
      heading="Stop typing out formatting rules."
      subtext="ThinkMode+ injects a persistent formatting bar right above your ChatGPT chatbox, allowing you to request Tables, Code, and Lists with a single click."
      link="/#features"
      btnText="Discover ThinkMode+"
    />
  </div>

  <style>
    .tool-page { max-width: 960px; margin: 0 auto; padding: 32px 24px 80px; }

    .gallery-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 64px; }
    @media (max-width: 768px) { .gallery-grid { grid-template-columns: 1fr; } }

    .format-card { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 16px; padding: 24px; display: flex; flex-direction: column; transition: transform 0.2s, box-shadow 0.2s; }
    .format-card:hover { transform: translateY(-2px); box-shadow: 0 12px 30px rgba(0,0,0,0.05); }
    
    .format-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
    .format-header h2 { margin: 0; font-size: 18px; font-weight: 700; }
    .format-desc { color: var(--text-dim); font-size: 14px; margin: 0 0 16px; line-height: 1.5; }
    
    .format-code { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 16px; font-family: var(--mono); font-size: 13px; color: var(--text); line-height: 1.6; white-space: pre-wrap; margin-top: auto; }
    
    .copy-btn { padding: 6px 12px; background: var(--surface-2); border: 1px solid var(--border-hi); border-radius: 6px; color: var(--text); font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
    .copy-btn:hover { background: var(--border); }
    .copy-btn:active { transform: scale(0.95); }
    .copy-btn:focus-visible { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px rgba(186, 58, 184, 0.2); }
    .copy-btn.copied { color: #22c55e; border-color: rgba(34,197,94,0.4); }

    .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); border: 0; }
  </style>

  <script>
    document.addEventListener('astro:page-load', () => {
      const copyTimers = new Map();
      const srAnnouncer = document.getElementById('sr-announcer');

      document.querySelectorAll('.copy-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const target = e.target;
          const text = target.getAttribute('data-content');
          try {
            await navigator.clipboard.writeText(text);
            if (srAnnouncer) srAnnouncer.textContent = "Template copied to clipboard";
            
            const orig = target.getAttribute('data-orig') || target.textContent;
            target.setAttribute('data-orig', orig);
            target.textContent = 'Copied!';
            target.classList.add('copied');
            
            if (copyTimers.has(target)) clearTimeout(copyTimers.get(target));

            const timerId = setTimeout(() => {
              target.textContent = orig;
              target.classList.remove('copied');
              copyTimers.delete(target);
            }, 2000);
            
            copyTimers.set(target, timerId);
          } catch (err) {
            console.error('Copy failed');
          }
        });
      });
    });
  </script>
</BaseLayout>
