---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolHero from '../../components/ToolHero.astro';
import BridgeCTA from '../../components/BridgeCTA.astro';
---

<BaseLayout
  title="Free ChatGPT Text Splitter | Bypass Character Limits & Chunk Prompts"
  description="Easily split long documents and text into manageable chunks for ChatGPT, Claude, and other AI models. Work around character limits with our free AI text chunker."
  canonicalPath="/tools/text-splitter"
>
  <Fragment slot="head">
    <meta name="keywords" content="ChatGPT text splitter, Split text for ChatGPT, AI text chunker, ChatGPT character limit bypass, ChatGPT long document splitter, Split long text for AI">

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "AI Text Splitter for ChatGPT",
      "url": "https://thinkmodeplus.com/tools/text-splitter",
      "description": "Split massive documents into perfect, prompt-ready chunks to bypass AI character limits.",
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": "How to bypass ChatGPT character limits by splitting text",
      "description": "Use the AI Text Splitter to chunk large documents into pieces small enough for ChatGPT to process.",
      "step": [
        { "@type": "HowToStep", "name": "Paste Document", "text": "Paste your large text, code, or essay into the splitter input box." },
        { "@type": "HowToStep", "name": "Select Chunk Size", "text": "Choose a target character limit based on the AI model you are using." },
        { "@type": "HowToStep", "name": "Copy Chunks", "text": "Copy each generated chunk sequentially and paste it into ChatGPT." }
      ]
    })} />
  </Fragment>

  <div class="tool-page">
    <ToolHero 
      title="Free AI Text Splitter for ChatGPT"
      subtitle="Paste your massive document below. We'll automatically split it into prompt-ready chunks so you can bypass ChatGPT's character limits."
      breadcrumbToolName="Text Splitter"
      toolPath="/tools/text-splitter"
    />

    <div class="splitter-tool">
      <div class="input-section">
        <div class="input-header">
          <label for="source-text" class="section-label">Your Document</label>
          <button id="clear-btn" class="ghost-btn">Clear Input</button>
        </div>
        <textarea id="source-text" placeholder="Paste your very long text here (e.g., codebases, PDF content, essays)..."></textarea>
        
        <div class="controls-bar">
          <div class="control-group">
            <label for="chunk-size">Target AI Model Limit</label>
            <select id="chunk-size">
              <option value="12000">ChatGPT Free (Safe: ~12,000 chars)</option>
              <option value="25000">ChatGPT Plus (Safe: ~25,000 chars)</option>
              <option value="8000">Conservative (Safe: ~8,000 chars)</option>
            </select>
          </div>
          <button id="split-btn" class="action-btn">Split Text</button>
        </div>
      </div>

      <div class="output-section" id="output-section" style="display: none;">
        <h2 class="section-label">Your Chunks</h2>
        <p class="output-helper">Copy and paste these chunks one by one into your AI chat.</p>
        <!-- ARIA Live region for screen readers -->
        <div aria-live="polite" class="sr-only" id="sr-announcer"></div>
        <div id="chunks-container" class="chunks-container"></div>
      </div>
    </div>

    <BridgeCTA 
      heading="Now that your data is loaded..."
      subtext="You need to extract it perfectly. ThinkMode+ injects a persistent formatting bar into ChatGPT, allowing you to request Markdown Tables, JSON, and Lists with one click."
      link="/#features"
      btnText="Discover ThinkMode+"
    />
  </div>

  <style>
    .tool-page { max-width: 960px; margin: 0 auto; padding: 32px 24px 80px; }
    
    .splitter-tool { display: flex; flex-direction: column; gap: 32px; margin-bottom: 64px; }
    
    .input-section, .output-section { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 16px; padding: 24px; }
    
    .input-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
    .section-label { display: block; font-size: 16px; font-weight: 600; margin: 0; }
    .ghost-btn { background: transparent; border: none; color: var(--text-dim); font-size: 13px; cursor: pointer; transition: color 0.2s; padding: 4px 8px; }
    .ghost-btn:hover { color: var(--accent-pink); }
    
    #source-text { width: 100%; min-height: 250px; background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 16px; color: var(--text); font-family: var(--display); font-size: 14px; line-height: 1.6; resize: vertical; margin-bottom: 16px; transition: border-color 0.3s, box-shadow 0.3s; }
    #source-text:focus-visible { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px rgba(186, 58, 184, 0.2); }
    #source-text.error { border-color: #ef4444; animation: shake 0.4s; }
    
    .controls-bar { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
    .control-group label { display: block; font-size: 12px; color: var(--text-dim); margin-bottom: 6px; }
    select { padding: 8px 12px; background: var(--surface); border: 1px solid var(--border-hi); border-radius: 8px; color: var(--text); font-size: 14px; transition: border-color 0.2s; }
    select:focus-visible { outline: none; border-color: var(--accent); }
    
    .action-btn { padding: 10px 24px; background: var(--accent); color: #fff; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); }
    .action-btn:hover { background: #d040ce; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(186, 58, 184, 0.2); }
    .action-btn:active { transform: scale(0.98); }
    
    .output-helper { font-size: 14px; color: var(--text-dim); margin: 0 0 20px; }
    
    .chunks-container { display: flex; flex-direction: column; gap: 16px; }
    .chunk-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; animation: fadeUp 0.4s ease forwards; opacity: 0; transform: translateY(10px); }
    .chunk-header { display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; background: rgba(255,255,255,0.02); border-bottom: 1px solid var(--border); }
    .chunk-title { font-weight: 600; font-size: 14px; color: var(--accent-pink); }
    .chunk-text { padding: 16px; font-family: var(--mono); font-size: 13px; color: var(--text-dim); max-height: 150px; overflow-y: auto; white-space: pre-wrap; }
    
    .chunk-copy-btn { padding: 6px 12px; background: var(--surface-2); border: 1px solid var(--border-hi); border-radius: 6px; color: var(--text); font-size: 12px; cursor: pointer; transition: all 0.2s; }
    .chunk-copy-btn:hover { background: var(--border); }
    .chunk-copy-btn:active { transform: scale(0.95); }
    .chunk-copy-btn.copied { color: #22c55e; border-color: rgba(34,197,94,0.4); }

    .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); border: 0; }

    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-5px); }
      75% { transform: translateX(5px); }
    }
    @keyframes fadeUp {
      to { opacity: 1; transform: translateY(0); }
    }
  </style>

  <script>
    document.addEventListener('astro:page-load', () => {
      const splitBtn = document.getElementById('split-btn');
      const sourceInput = document.getElementById('source-text');
      const sizeSelect = document.getElementById('chunk-size');
      const outputSection = document.getElementById('output-section');
      const chunksContainer = document.getElementById('chunks-container');
      const clearBtn = document.getElementById('clear-btn');
      const srAnnouncer = document.getElementById('sr-announcer');

      if (!splitBtn || !sourceInput) return;

      // Restore session storage
      const savedText = sessionStorage.getItem('ts_source_text');
      if (savedText) sourceInput.value = savedText;
      sourceInput.addEventListener('input', () => {
        sourceInput.classList.remove('error');
        sessionStorage.setItem('ts_source_text', sourceInput.value);
      });

      clearBtn.addEventListener('click', () => {
        sourceInput.value = '';
        sessionStorage.removeItem('ts_source_text');
        outputSection.style.display = 'none';
        sourceInput.focus();
      });

      function splitText(text, maxChars) {
        const safeLimit = maxChars - 150;
        const chunks = [];
        let currentIdx = 0;

        while (currentIdx < text.length) {
          let nextIdx = currentIdx + safeLimit;
          if (nextIdx >= text.length) {
            chunks.push(text.slice(currentIdx));
            break;
          }
          
          let chunkStr = text.slice(currentIdx, nextIdx);
          
          // Smart splitting: avoid breaking inside code blocks (```) if possible
          const lastCodeFence = chunkStr.lastIndexOf('```');
          const isInsideCode = (chunkStr.match(/```/g) || []).length % 2 !== 0;
          
          let breakIdx = -1;
          
          if (isInsideCode && lastCodeFence > 0) {
            // Cut before the code block started to keep it intact
            breakIdx = currentIdx + lastCodeFence;
          } else {
            // Natural break hierarchy
            breakIdx = text.lastIndexOf('\n\n', nextIdx);
            if (breakIdx <= currentIdx) breakIdx = text.lastIndexOf('\n', nextIdx);
            if (breakIdx <= currentIdx) breakIdx = text.lastIndexOf(' ', nextIdx);
          }
          
          // Fallback if no natural break found
          if (breakIdx <= currentIdx) breakIdx = nextIdx;
          
          chunks.push(text.slice(currentIdx, breakIdx).trim());
          currentIdx = breakIdx;
        }
        return chunks;
      }

      splitBtn.addEventListener('click', () => {
        const text = sourceInput.value.trim();
        if (!text) {
          sourceInput.classList.add('error');
          sourceInput.focus();
          return;
        }

        const maxChars = parseInt(sizeSelect.value, 10);
        const rawChunks = splitText(text, maxChars);
        const total = rawChunks.length;

        chunksContainer.innerHTML = '';
        
        rawChunks.forEach((chunk, index) => {
          const partNum = index + 1;
          let wrappedText = '';
          if (partNum === 1 && total > 1) {
            wrappedText = `[Part 1 of ${total}] I am going to send you a large document in multiple parts. Do NOT reply or summarize until I say "ALL PARTS RECEIVED". Acknowledge this part by saying "Part 1 received".\n\n${chunk}`;
          } else if (partNum === total) {
            wrappedText = `[Part ${partNum} of ${total}] Here is the final part of the document:\n\n${chunk}\n\nALL PARTS RECEIVED. You may now process the complete document.`;
          } else {
            wrappedText = `[Part ${partNum} of ${total}] Do NOT reply or summarize yet. Acknowledge this part by saying "Part ${partNum} received".\n\n${chunk}`;
          }

          const card = document.createElement('div');
          card.className = 'chunk-card';
          card.style.animationDelay = `${index * 0.1}s`;
          card.innerHTML = `
            <div class="chunk-header">
              <span class="chunk-title">Part ${partNum} of ${total}</span>
              <button class="chunk-copy-btn" data-content="${encodeURIComponent(wrappedText)}">Copy Part ${partNum}</button>
            </div>
            <div class="chunk-text">${wrappedText.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</div>
          `;
          chunksContainer.appendChild(card);
        });

        outputSection.style.display = 'block';
        
        // Smart scroll (only scroll if offscreen)
        const rect = outputSection.getBoundingClientRect();
        if (rect.bottom > window.innerHeight) {
          outputSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });

      // Delegate copy events
      const copyTimers = new Map();
      chunksContainer.addEventListener('click', async (e) => {
        if (e.target.classList.contains('chunk-copy-btn')) {
          const btn = e.target;
          const text = decodeURIComponent(btn.getAttribute('data-content'));
          try {
            await navigator.clipboard.writeText(text);
            
            // Screen reader announcement
            srAnnouncer.textContent = `Part copied to clipboard`;
            
            const origText = btn.getAttribute('data-orig') || btn.textContent;
            btn.setAttribute('data-orig', origText);
            btn.textContent = 'Copied!';
            btn.classList.add('copied');
            
            if (copyTimers.has(btn)) clearTimeout(copyTimers.get(btn));
            
            const timerId = setTimeout(() => {
              btn.textContent = origText;
              btn.classList.remove('copied');
              copyTimers.delete(btn);
            }, 2000);
            
            copyTimers.set(btn, timerId);
          } catch (err) {
            console.error('Copy failed', err);
          }
        }
      });
    });
  </script>
</BaseLayout>
