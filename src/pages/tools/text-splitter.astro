---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Free ChatGPT Text Splitter | Bypass Character Limits & Chunk Prompts"
  description="Easily split long documents and text into manageable chunks for ChatGPT, Claude, and other AI models. Work around character limits with our free AI text chunker."
  canonicalPath="/tools/text-splitter"
>
  <Fragment slot="head">
    <meta name="keywords" content="ChatGPT text splitter, Split text for ChatGPT, AI text chunker, ChatGPT character limit bypass, ChatGPT long document splitter, Split long text for AI">

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "AI Text Splitter for ChatGPT",
      "url": "https://thinkmodeplus.com/tools/text-splitter",
      "description": "Split massive documents into perfect, prompt-ready chunks to bypass AI character limits.",
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    })} />
  </Fragment>

  <div class="tool-page">
    <!-- Hero -->
    <div class="tool-hero">
      <div class="tool-breadcrumb">
        <a href="/">ThinkMode+</a>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        <a href="/tools">Tools</a>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        <a href="/tools/text-splitter">Text Splitter</a>
      </div>
      <h1>Free AI Text Splitter for ChatGPT</h1>
      <p class="tool-subtitle">Paste your massive document below. We'll automatically split it into prompt-ready chunks so you can bypass ChatGPT's character limits.</p>
    </div>

    <div class="splitter-tool">
      <div class="input-section">
        <label for="source-text" class="section-label">Your Document</label>
        <textarea id="source-text" placeholder="Paste your very long text here (e.g., codebases, PDF content, essays)..."></textarea>
        
        <div class="controls-bar">
          <div class="control-group">
            <label for="chunk-size">Target AI Model Limit</label>
            <select id="chunk-size">
              <option value="12000">ChatGPT Free (Safe: ~12,000 chars)</option>
              <option value="25000">ChatGPT Plus (Safe: ~25,000 chars)</option>
              <option value="8000">Conservative (Safe: ~8,000 chars)</option>
            </select>
          </div>
          <button id="split-btn" class="action-btn">Split Text</button>
        </div>
      </div>

      <div class="output-section" id="output-section" style="display: none;">
        <h2 class="section-label">Your Chunks</h2>
        <p class="output-helper">Copy and paste these chunks one by one into your AI chat.</p>
        <div id="chunks-container" class="chunks-container"></div>
      </div>
    </div>

    <!-- Bridge CTA -->
    <div class="bridge-cta">
      <div class="bridge-content">
        <div class="bridge-icon">
          <img src="/logo.png" alt="ThinkMode+" width="40" height="40" style="object-fit: contain;" />
        </div>
        <div class="bridge-text">
          <h3>Now that your data is loaded...</h3>
          <p>You need to extract it perfectly. ThinkMode+ injects a persistent formatting bar into ChatGPT, allowing you to request Markdown Tables, JSON, and Lists with one click.</p>
        </div>
        <a href="/" class="bridge-btn">Discover ThinkMode+</a>
      </div>
    </div>
  </div>

  <style>
    .tool-page { max-width: 960px; margin: 0 auto; padding: 32px 24px 80px; }
    .tool-hero { margin-bottom: 48px; }
    .tool-breadcrumb { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text-faint); margin-bottom: 20px; }
    .tool-breadcrumb a { color: var(--text-dim); text-decoration: none; }
    .tool-breadcrumb a:hover { color: var(--text); }
    .tool-breadcrumb svg { opacity: 0.4; }
    .tool-hero h1 { font-size: 36px; font-weight: 700; margin: 0 0 12px; }
    .tool-subtitle { font-size: 17px; color: var(--text-dim); max-width: 640px; margin: 0; }

    .splitter-tool { display: flex; flex-direction: column; gap: 32px; margin-bottom: 64px; }
    
    .input-section, .output-section { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 16px; padding: 24px; }
    .section-label { display: block; font-size: 16px; font-weight: 600; margin-bottom: 12px; }
    
    #source-text { width: 100%; min-height: 250px; background: rgba(0,0,0,0.2); border: 1px solid var(--border); border-radius: 10px; padding: 16px; color: var(--text); font-family: var(--display); font-size: 14px; line-height: 1.6; resize: vertical; margin-bottom: 16px; }
    #source-text:focus { outline: none; border-color: var(--accent); }
    
    .controls-bar { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
    .control-group label { display: block; font-size: 12px; color: var(--text-dim); margin-bottom: 6px; }
    select { padding: 8px 12px; background: var(--surface); border: 1px solid var(--border-hi); border-radius: 8px; color: var(--text); font-size: 14px; }
    
    .action-btn { padding: 10px 24px; background: var(--accent); color: #fff; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; transition: background 0.2s; }
    .action-btn:hover { background: #d040ce; }
    
    .output-helper { font-size: 14px; color: var(--text-dim); margin: 0 0 20px; }
    
    .chunks-container { display: flex; flex-direction: column; gap: 16px; }
    .chunk-card { background: rgba(0,0,0,0.3); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
    .chunk-header { display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; background: rgba(255,255,255,0.02); border-bottom: 1px solid var(--border); }
    .chunk-title { font-weight: 600; font-size: 14px; color: var(--accent-pink); }
    .chunk-text { padding: 16px; font-family: var(--mono); font-size: 13px; color: var(--text-dim); max-height: 150px; overflow-y: auto; white-space: pre-wrap; }
    
    .chunk-copy-btn { padding: 6px 12px; background: var(--surface); border: 1px solid var(--border-hi); border-radius: 6px; color: var(--text); font-size: 12px; cursor: pointer; }
    .chunk-copy-btn:hover { background: var(--surface-2); }
    .chunk-copy-btn.copied { color: #22c55e; border-color: rgba(34,197,94,0.4); }

    /* Bridge CTA */
    .bridge-cta { background: linear-gradient(135deg, rgba(186, 58, 184, 0.08), rgba(137, 20, 183, 0.06)); border: 1px solid rgba(186, 58, 184, 0.15); border-radius: 16px; padding: 32px; display: flex; align-items: center; gap: 24px; }
    .bridge-icon { width: 56px; height: 56px; background: rgba(255,255,255,0.05); border-radius: 14px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .bridge-text { flex: 1; }
    .bridge-text h3 { margin: 0 0 6px; font-size: 18px; font-weight: 600; }
    .bridge-text p { margin: 0; font-size: 14px; color: var(--text-dim); }
    .bridge-btn { padding: 12px 24px; background: var(--accent); color: #fff; border-radius: 10px; text-decoration: none; font-weight: 600; flex-shrink: 0; }
    .bridge-btn:hover { background: #d040ce; }
  </style>

  <script>
    document.addEventListener('astro:page-load', () => {
      const splitBtn = document.getElementById('split-btn');
      const sourceInput = document.getElementById('source-text');
      const sizeSelect = document.getElementById('chunk-size');
      const outputSection = document.getElementById('output-section');
      const chunksContainer = document.getElementById('chunks-container');

      if (!splitBtn || !sourceInput) return;

      function splitText(text, maxChars) {
        // Reserve some space for the instruction wrapper (approx 100 chars)
        const safeLimit = maxChars - 150;
        const chunks = [];
        let currentIdx = 0;

        while (currentIdx < text.length) {
          let nextIdx = currentIdx + safeLimit;
          if (nextIdx >= text.length) {
            chunks.push(text.slice(currentIdx));
            break;
          }
          
          // Try to break at a double newline, single newline, or space
          let breakIdx = text.lastIndexOf('\n\n', nextIdx);
          if (breakIdx <= currentIdx) breakIdx = text.lastIndexOf('\n', nextIdx);
          if (breakIdx <= currentIdx) breakIdx = text.lastIndexOf(' ', nextIdx);
          
          // Fallback if no natural break found
          if (breakIdx <= currentIdx) breakIdx = nextIdx;
          
          chunks.push(text.slice(currentIdx, breakIdx).trim());
          currentIdx = breakIdx;
        }
        return chunks;
      }

      splitBtn.addEventListener('click', () => {
        const text = sourceInput.value.trim();
        if (!text) return;

        const maxChars = parseInt(sizeSelect.value, 10);
        const rawChunks = splitText(text, maxChars);
        const total = rawChunks.length;

        chunksContainer.innerHTML = '';
        
        rawChunks.forEach((chunk, index) => {
          const partNum = index + 1;
          // Create the wrapped prompt
          let wrappedText = '';
          if (partNum === 1 && total > 1) {
            wrappedText = `[Part 1 of ${total}] I am going to send you a large document in multiple parts. Do NOT reply or summarize until I say "ALL PARTS RECEIVED". Acknowledge this part by saying "Part 1 received".\n\n${chunk}`;
          } else if (partNum === total) {
            wrappedText = `[Part ${partNum} of ${total}] Here is the final part of the document:\n\n${chunk}\n\nALL PARTS RECEIVED. You may now process the complete document.`;
          } else {
            wrappedText = `[Part ${partNum} of ${total}] Do NOT reply or summarize yet. Acknowledge this part by saying "Part ${partNum} received".\n\n${chunk}`;
          }

          const card = document.createElement('div');
          card.className = 'chunk-card';
          card.innerHTML = `
            <div class="chunk-header">
              <span class="chunk-title">Part ${partNum} of ${total}</span>
              <button class="chunk-copy-btn" data-content="${encodeURIComponent(wrappedText)}">Copy Part ${partNum}</button>
            </div>
            <div class="chunk-text">${wrappedText.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</div>
          `;
          chunksContainer.appendChild(card);
        });

        outputSection.style.display = 'block';
        outputSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });

      // Delegate copy events
      chunksContainer.addEventListener('click', async (e) => {
        if (e.target.classList.contains('chunk-copy-btn')) {
          const btn = e.target;
          const text = decodeURIComponent(btn.getAttribute('data-content'));
          try {
            await navigator.clipboard.writeText(text);
            const origText = btn.textContent;
            btn.textContent = 'Copied!';
            btn.classList.add('copied');
            setTimeout(() => {
              btn.textContent = origText;
              btn.classList.remove('copied');
            }, 2000);
          } catch (err) {
            console.error('Copy failed', err);
          }
        }
      });
    });
  </script>
</BaseLayout>
