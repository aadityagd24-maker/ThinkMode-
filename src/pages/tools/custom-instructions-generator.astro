---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolHero from '../../components/ToolHero.astro';
import BridgeCTA from '../../components/BridgeCTA.astro';
import RelatedTools from '../../components/RelatedTools.astro';

const roles = [
  { id: 'swe', name: 'Software Engineer', icon: '💻' },
  { id: 'copywriter', name: 'Copywriter', icon: '✍️' },
  { id: 'marketer', name: 'Marketer', icon: '📈' },
  { id: 'teacher', name: 'Tutor / Teacher', icon: '🎓' },
  { id: 'data', name: 'Data Analyst', icon: '📊' },
  { id: 'product', name: 'Product Manager', icon: '🚀' },
  { id: 'designer', name: 'UX/UI Designer', icon: '🎨' },
  { id: 'seo', name: 'SEO Specialist', icon: '🔍' },
  { id: 'sales', name: 'Sales Professional', icon: '🤝' },
  { id: 'coach', name: 'Life / Exec Coach', icon: '🧭' },
  { id: 'assistant', name: 'Exec Assistant', icon: '📋' },
  { id: 'legal', name: 'Legal Advisor', icon: '⚖️' }
];

const tones = [
  { id: 'professional', name: 'Professional & Formal' },
  { id: 'friendly', name: 'Friendly & Conversational' },
  { id: 'direct', name: 'Direct & Concise' },
  { id: 'thorough', name: 'Thorough & Detailed' },
  { id: 'socratic', name: 'Socratic (Ask Questions)' }
];

const formats = [
  { id: 'structured', name: 'Structured (Headers & Bullets)' },
  { id: 'step-by-step', name: 'Step-by-step Guides' },
  { id: 'concise', name: 'Short Paragraphs (No fluff)' },
  { id: 'code-first', name: 'Code First, Explanations Second' },
  { id: 'table', name: 'Tables for Data' }
];

const extras = [
  { id: 'none', name: 'None' },
  { id: 'no-fluff', name: 'Skip pleasantries (No "Certainly!")' },
  { id: 'cite-sources', name: 'Cite sources for factual claims' },
  { id: 'ask-clarify', name: 'Ask clarifying questions if ambiguous' },
  { id: 'eli5', name: 'Explain Like I\'m 5 (Beginner friendly)' },
  { id: 'challenge', name: 'Challenge my assumptions (Devil\'s advocate)' }
];
---

<BaseLayout
  title="Free ChatGPT Custom Instructions Generator — Create Perfect System Prompts | ThinkMode+"
  description="Generate optimized custom instructions for ChatGPT in seconds. Select a role, tone, and format to instantly create expert-level system prompts for coding, writing, marketing, and more. Free, no signup required."
  canonicalPath="/tools/custom-instructions-generator"
>
  <Fragment slot="head">
    <meta name="keywords" content="chatgpt custom instructions generator, chatgpt system prompt generator, custom instructions templates chatgpt, best custom instructions for chatgpt, chatgpt persona generator, how to write custom instructions chatgpt, chatgpt system prompt templates, chatgpt expert mode, ai prompt generator">

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "ChatGPT Custom Instructions Generator",
      "url": "https://thinkmodeplus.com/tools/custom-instructions-generator",
      "description": "Generate optimized custom instructions for ChatGPT. Select a role, tone, and format to instantly create expert-level system prompts.",
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "author": { "@type": "Organization", "name": "ThinkMode+" }
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": "How to Generate Custom Instructions for ChatGPT",
      "description": "Use this free tool to create optimized system prompts for ChatGPT in 3 simple steps.",
      "step": [
        { "@type": "HowToStep", "name": "Choose a Role", "text": "Select what expert persona ChatGPT should adopt." },
        { "@type": "HowToStep", "name": "Set Tone & Format", "text": "Pick how ChatGPT should communicate and structure its responses." },
        { "@type": "HowToStep", "name": "Copy & Paste", "text": "Copy the generated instructions and paste them into ChatGPT's Custom Instructions settings." }
      ]
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "What are ChatGPT Custom Instructions?", "acceptedAnswer": { "@type": "Answer", "text": "They are permanent rules you can set in ChatGPT so it always remembers how you want it to act, format responses, or what constraints to follow." } },
        { "@type": "Question", "name": "How do I use this generator?", "acceptedAnswer": { "@type": "Answer", "text": "Select an expert persona, set the output style, and copy the generated block of text directly into your ChatGPT settings." } }
      ]
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thinkmodeplus.com/" },
        { "@type": "ListItem", "position": 2, "name": "Tools", "item": "https://thinkmodeplus.com/tools" },
        { "@type": "ListItem", "position": 3, "name": "Custom Instructions Generator", "item": "https://thinkmodeplus.com/tools/custom-instructions-generator" }
      ]
    })} />
  </Fragment>

  <div class="tool-page">
    <ToolHero 
      title="ChatGPT Custom Instructions Generator"
      subtitle="Select a role, tone, and format below to instantly generate the perfect system prompt. Paste it into ChatGPT's settings to permanently upgrade its intelligence."
      breadcrumbToolName="Custom Instructions"
      toolPath="/tools/custom-instructions-generator"
    />

    <div class="generator-tool">
      <!-- Config Panel -->
      <div class="config-panel">
        <div class="panel-section">
          <h2>1. Select Role</h2>
          <div class="role-grid">
            {roles.map(role => (
              <label class="role-card">
                <input type="radio" name="role" value={role.id} checked={role.id === 'swe'} />
                <span class="role-content">
                  <span class="role-icon">{role.icon}</span>
                  <span class="role-name">{role.name}</span>
                </span>
              </label>
            ))}
          </div>
        </div>

        <div class="panel-section split">
          <div class="field">
            <label for="tone-select">2. Tone of Voice</label>
            <select id="tone-select">
              {tones.map(t => <option value={t.id} selected={t.id === 'professional'}>{t.name}</option>)}
            </select>
          </div>
          <div class="field">
            <label for="format-select">3. Output Format</label>
            <select id="format-select">
              {formats.map(f => <option value={f.id} selected={f.id === 'structured'}>{f.name}</option>)}
            </select>
          </div>
        </div>

        <div class="panel-section">
          <div class="field">
            <label for="extras-select">4. Extra Rules (Optional)</label>
            <select id="extras-select">
              {extras.map(e => <option value={e.id} selected={e.id === 'none'}>{e.name}</option>)}
            </select>
          </div>
        </div>
      </div>

      <!-- Preview Panel -->
      <div class="preview-panel">
        <div class="preview-header">
          <div class="preview-title">
            <h2>Your Custom Instructions</h2>
            <div class="char-counter" id="char-counter">
              <span id="char-count">0</span> / 1500 chars
            </div>
          </div>
          <button id="copy-btn" class="copy-btn">
            <svg id="copy-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
            <svg id="check-icon" style="display:none; color: #22c55e;" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span id="copy-text">Copy to Clipboard</span>
          </button>
        </div>

        <!-- ARIA Live region -->
        <div aria-live="polite" class="sr-only" id="sr-announcer"></div>

        <div class="output-box-container">
          <div id="output-box" class="output-box"></div>
        </div>
        
        <p class="preview-hint">ChatGPT has a strict 1,500 character limit for custom instructions. Keep an eye on the counter above!</p>
      </div>
    </div>

    <!-- How-to Section -->
    <div class="howto-section">
      <h2>How to apply these instructions</h2>
      <div class="howto-grid">
        <div class="howto-step">
          <div class="step-num">1</div>
          <div>
            <h3>Generate & Copy</h3>
            <p>Select your preferences above and click the "Copy to Clipboard" button. Ensure the character count is under 1,500.</p>
          </div>
        </div>
        <div class="howto-step">
          <div class="step-num">2</div>
          <div>
            <h3>Open Settings</h3>
            <p>Open ChatGPT, click on your profile icon in the bottom-left corner, and select "Customize ChatGPT".</p>
          </div>
        </div>
        <div class="howto-step">
          <div class="step-num">3</div>
          <div>
            <h3>Paste into ChatGPT</h3>
            <p>Paste into the "How would you like ChatGPT to respond?" field and hit Save.</p>
          </div>
        </div>
      </div>
    </div>

    <BridgeCTA 
      heading="Tired of manually setting rules?"
      subtext="ThinkMode+ adds a permanent Expert Role button directly inside ChatGPT so you can switch personas on the fly, plus auto-enable extended thinking on every chat."
      link="/#features"
      btnText="Explore ThinkMode+"
    />
    
    <RelatedTools />
  </div>

  <style>
    .tool-page { max-width: 1100px; margin: 0 auto; padding: 32px 24px 80px; }

    .generator-tool { display: grid; grid-template-columns: 1fr 1.1fr; gap: 32px; margin-bottom: 64px; }
    @media (max-width: 900px) { .generator-tool { grid-template-columns: 1fr; } }

    .config-panel { display: flex; flex-direction: column; gap: 24px; }
    .panel-section { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 16px; padding: 24px; }
    .panel-section.split { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    @media (max-width: 600px) { .panel-section.split { grid-template-columns: 1fr; } }

    .panel-section h2, .field label { display: block; font-size: 15px; font-weight: 600; margin: 0 0 16px; color: var(--text); }
    .field label { margin: 0 0 8px; }

    .role-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 12px; }
    .role-card { cursor: pointer; position: relative; }
    .role-card input { position: absolute; opacity: 0; cursor: pointer; }
    .role-content { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; padding: 16px 12px; background: var(--surface); border: 1px solid var(--border-hi); border-radius: 12px; text-align: center; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); }
    
    .role-card:hover .role-content { background: var(--surface-2); border-color: var(--border-hi); }
    .role-card input:checked ~ .role-content { background: rgba(186, 58, 184, 0.1); border-color: var(--accent); box-shadow: 0 4px 12px rgba(186, 58, 184, 0.15); }
    .role-card input:focus-visible ~ .role-content { outline: 2px solid var(--accent); outline-offset: 2px; }
    
    .role-icon { font-size: 24px; }
    .role-name { font-size: 12px; font-weight: 500; color: var(--text-dim); }
    .role-card input:checked ~ .role-content .role-name { color: var(--accent-pink); font-weight: 600; }

    select { width: 100%; padding: 10px 12px; background: var(--surface); border: 1px solid var(--border-hi); border-radius: 8px; color: var(--text); font-size: 14px; transition: border-color 0.2s; }
    select:focus-visible { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px rgba(186, 58, 184, 0.2); }

    .preview-panel { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 16px; padding: 24px; display: flex; flex-direction: column; }
    .preview-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 16px; flex-wrap: wrap; gap: 16px; }
    .preview-title h2 { font-size: 18px; font-weight: 600; margin: 0 0 8px; }
    
    .char-counter { font-size: 13px; font-family: var(--mono); color: var(--text-dim); background: var(--surface); padding: 4px 8px; border-radius: 6px; border: 1px solid var(--border); display: inline-block; transition: color 0.3s, border-color 0.3s; }
    .char-counter.near-limit { color: #f59e0b; border-color: rgba(245, 158, 11, 0.4); }
    .char-counter.over-limit { color: #ef4444; border-color: rgba(239, 68, 68, 0.4); font-weight: bold; }

    .copy-btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 16px; background: var(--accent); color: #fff; border: none; border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); }
    .copy-btn:hover { background: #d040ce; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(186, 58, 184, 0.2); }
    .copy-btn:active { transform: scale(0.98); }
    .copy-btn:focus-visible { outline: none; box-shadow: 0 0 0 3px rgba(186, 58, 184, 0.4); }
    .copy-btn.copied { background: #22c55e; }

    .output-box-container { flex: 1; min-height: 400px; display: flex; flex-direction: column; }
    .output-box { flex: 1; background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 20px; font-family: var(--mono); font-size: 14px; color: var(--text); line-height: 1.6; white-space: pre-wrap; overflow-y: auto; transition: background-color 0.3s; }
    .output-box.updated { background-color: rgba(186, 58, 184, 0.1); }
    
    .preview-hint { font-size: 13px; color: var(--text-faint); margin: 16px 0 0; text-align: center; }

    .howto-section { margin-bottom: 64px; }
    .howto-section h2 { font-size: 24px; font-weight: 700; margin-bottom: 24px; text-align: center; }
    .howto-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    @media (max-width: 768px) { .howto-grid { grid-template-columns: 1fr; } }
    .howto-step { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 16px; padding: 24px; display: flex; gap: 16px; align-items: flex-start; }
    .step-num { width: 32px; height: 32px; background: rgba(186, 58, 184, 0.1); color: var(--accent-pink); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; flex-shrink: 0; }
    .howto-step h3 { margin: 0 0 8px; font-size: 16px; font-weight: 600; }
    .howto-step p { margin: 0; font-size: 14px; color: var(--text-dim); line-height: 1.5; }

    .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); border: 0; }
  </style>

  <script>
    document.addEventListener('astro:page-load', () => {
      // Setup roles object
      const rolesData = {
        'swe': { instructions: "You are a Senior Software Engineer with deep expertise in full-stack web development, system architecture, and clean code principles. Provide robust, production-ready code with appropriate error handling. Prioritize security, performance, and readability." },
        'copywriter': { instructions: "You are an Expert Copywriter specializing in high-converting, persuasive text. Your writing is engaging, clear, and emotionally resonant. Focus on benefits over features, use active voice, and structure text for readability." },
        'marketer': { instructions: "You are a Growth Marketing Strategist. You understand user acquisition, conversion rate optimization, and psychological triggers. Base your recommendations on data and proven marketing frameworks." },
        'teacher': { instructions: "You are a World-Class Tutor. You excel at breaking down complex concepts into simple, understandable pieces. You are patient, encouraging, and use analogies effectively." },
        'data': { instructions: "You are a Senior Data Analyst. You are highly analytical, precise, and objective. Focus on statistical significance, actionable insights, and data visualization best practices." },
        'product': { instructions: "You are a Senior Product Manager. You focus on user needs, business value, and prioritization. Help frame problems, define MVP scopes, and strategize roadmaps." },
        'designer': { instructions: "You are a Lead UX/UI Designer. You care deeply about usability, accessibility, and visual hierarchy. Provide critique and suggestions based on modern design systems." },
        'seo': { instructions: "You are an SEO Specialist. Focus on search intent, keyword optimization, technical SEO best practices, and creating content that ranks while remaining valuable to humans." },
        'sales': { instructions: "You are a B2B Sales Expert. Focus on objection handling, value proposition, and closing strategies. Communicate confidently and persuasively." },
        'coach': { instructions: "You are an Executive/Life Coach. Listen actively, ask probing questions, and help guide the user to their own insights. Focus on actionable habits and mindset shifts." },
        'assistant': { instructions: "You are a highly capable Executive Assistant. You are highly organized, proactive, and concise. Help schedule, summarize, and manage tasks efficiently." },
        'legal': { instructions: "You are a Legal Advisor. Provide structured, precise, and risk-aware information. Always clarify that you are providing informational guidance, not formal legal counsel." }
      };

      const tonesData = {
        'professional': `Maintain a professional and formal tone. Use precise language, avoid slang.`,
        'friendly': `Be warm, approachable, and conversational. Use a natural speaking voice.`,
        'direct': `Be extremely direct and concise. No preambles, no filler. Get straight to the answer.`,
        'thorough': `Be comprehensive and detailed. Cover all angles and edge cases.`,
        'socratic': `Teach through questions rather than direct answers. Guide discovery.`
      };

      const formatsData = {
        'structured': `Structure every response with clear headings (##) and bullet points. Break complex answers into sections.`,
        'step-by-step': `Present information as numbered step-by-step instructions. Each step should be one clear action.`,
        'concise': `Use clear, concise paragraphs. Prioritize readability over excessive structure.`,
        'code-first': `Lead with code for programming questions. Show working solution first, then explain.`,
        'table': `Use markdown tables to present comparisons and structured data whenever possible.`
      };

      const extrasData = {
        'none': '',
        'no-fluff': `\n\nAdditional rule: Skip all pleasantries, greetings, and filler phrases — just get to the substance immediately.`,
        'cite-sources': `\n\nAdditional rule: When making factual claims, cite your sources or indicate the basis of the information.`,
        'ask-clarify': `\n\nAdditional rule: If my request is ambiguous, ask a brief clarifying question before proceeding.`,
        'eli5': `\n\nAdditional rule: Default to simple, beginner-friendly explanations. Avoid jargon.`,
        'challenge': `\n\nAdditional rule: Point out flaws in my logic. Play devil's advocate when appropriate.`
      };

      // Restore session storage
      const savedRole = sessionStorage.getItem('cig_role');
      const savedTone = sessionStorage.getItem('cig_tone');
      const savedFormat = sessionStorage.getItem('cig_format');
      const savedExtra = sessionStorage.getItem('cig_extra');
      
      if (savedRole) {
        const rb = document.querySelector(`input[name="role"][value="${savedRole}"]`);
        if (rb) rb.checked = true;
      }
      if (savedTone) document.getElementById('tone-select').value = savedTone;
      if (savedFormat) document.getElementById('format-select').value = savedFormat;
      if (savedExtra) document.getElementById('extras-select').value = savedExtra;

      function generate() {
        const roleVal = document.querySelector('input[name="role"]:checked').value;
        const toneVal = document.getElementById('tone-select').value;
        const formatVal = document.getElementById('format-select').value;
        const extraVal = document.getElementById('extras-select').value;

        // Save state
        sessionStorage.setItem('cig_role', roleVal);
        sessionStorage.setItem('cig_tone', toneVal);
        sessionStorage.setItem('cig_format', formatVal);
        sessionStorage.setItem('cig_extra', extraVal);

        const role = rolesData[roleVal];
        const tone = tonesData[toneVal];
        const format = formatsData[formatVal];
        const extra = extrasData[extraVal];

        const output = `# Role & Expertise\n${role.instructions}\n\n# Communication Style\n${tone}\n\n# Response Format\n${format}${extra}`;

        const outputBox = document.getElementById('output-box');
        outputBox.textContent = output;
        
        // Flash interaction
        outputBox.classList.add('updated');
        setTimeout(() => outputBox.classList.remove('updated'), 300);

        // Update character counter
        const charCount = output.length;
        const charCountEl = document.getElementById('char-count');
        const charCounterEl = document.getElementById('char-counter');
        if (charCountEl && charCounterEl) {
          charCountEl.textContent = charCount.toLocaleString();
          charCounterEl.classList.remove('over-limit', 'near-limit');
          if (charCount > 1500) charCounterEl.classList.add('over-limit');
          else if (charCount > 1200) charCounterEl.classList.add('near-limit');
        }
      }

      // Generate on load and on change
      generate();
      document.querySelectorAll('select').forEach(el => el.addEventListener('change', generate));
      document.querySelectorAll('input[name="role"]').forEach(el => el.addEventListener('change', generate));

      // Copy button
      const copyBtn = document.getElementById('copy-btn');
      let copyTimerId = null;
      const srAnnouncer = document.getElementById('sr-announcer');
      
      if (copyBtn) {
        copyBtn.addEventListener('click', async () => {
          const text = document.getElementById('output-box').textContent;
          try {
            await navigator.clipboard.writeText(text);
            if (srAnnouncer) srAnnouncer.textContent = 'Custom instructions copied to clipboard';
            
            const copyIcon = document.getElementById('copy-icon');
            const checkIcon = document.getElementById('check-icon');
            const copyText = document.getElementById('copy-text');

            copyIcon.style.display = 'none';
            checkIcon.style.display = 'block';
            copyText.textContent = 'Copied!';
            copyBtn.classList.add('copied');

            if (copyTimerId) clearTimeout(copyTimerId);

            copyTimerId = setTimeout(() => {
              copyIcon.style.display = 'block';
              checkIcon.style.display = 'none';
              copyText.textContent = 'Copy to Clipboard';
              copyBtn.classList.remove('copied');
              copyTimerId = null;
            }, 2000);
          } catch (err) {
            console.error('Copy failed', err);
          }
        });
      }
    });
  </script>
</BaseLayout>
