---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolHero from '../../components/ToolHero.astro';
import BridgeCTA from '../../components/BridgeCTA.astro';
---

<BaseLayout
  title="Free AI Hallucination Fact-Checker Prompt Builder"
  description="Stop ChatGPT from making things up. Use our free AI Hallucination Fact-Checker Prompt Builder to generate prompts that verify facts and reduce AI errors."
  canonicalPath="/tools/hallucination-checker"
>
  <Fragment slot="head">
    <meta name="keywords" content="ChatGPT fact checker prompt, Reduce AI hallucination prompt, AI hallucination fact-checker prompt builder, Fact check prompt generator, How to stop ChatGPT from hallucinating, ChatGPT self reflection prompt">
    
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "AI Hallucination Fact-Checker Prompt Builder",
      "url": "https://thinkmodeplus.com/tools/hallucination-checker",
      "description": "Generate custom self-reflection prompts to stop AI hallucinations and verify facts.",
      "applicationCategory": "UtilityApplication"
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": "How to Fact-Check ChatGPT Outputs",
      "description": "Use a self-reflection prompt to force ChatGPT to audit its own answers for hallucinations.",
      "step": [
        { "@type": "HowToStep", "name": "Paste the Claim", "text": "Paste the suspicious AI output into the Fact-Checker input field." },
        { "@type": "HowToStep", "name": "Set Strictness", "text": "Choose whether you want a moderate review or a strict, highly skeptical audit." },
        { "@type": "HowToStep", "name": "Generate & Copy", "text": "Generate the prompt and copy it back into your ChatGPT conversation." }
      ]
    })} />
  </Fragment>

  <div class="tool-page">
    <ToolHero 
      title="Stop AI Hallucinations with the Free Fact-Checker Prompt Builder"
      subtitle="Build a powerful 'self-reflection' prompt that forces ChatGPT to audit its own previous answer for factual inaccuracies and logical flaws."
      breadcrumbToolName="Fact Checker"
      toolPath="/tools/hallucination-checker"
    />

    <div class="checker-tool">
      <!-- Input Section -->
      <div class="checker-panel input-panel">
        <div class="panel-header">
          <h2>1. Configure the Audit</h2>
          <button id="clear-btn" class="ghost-btn">Clear</button>
        </div>
        
        <div class="form-group">
          <label for="claim-input">What did the AI just tell you?</label>
          <textarea id="claim-input" placeholder="Paste the AI's previous output or specific claim here..."></textarea>
        </div>
        
        <div class="form-group">
          <label for="strictness-select">Fact-Check Strictness</label>
          <select id="strictness-select">
            <option value="moderate">Moderate (Find obvious errors)</option>
            <option value="strict">Strict (Demand citations and sources)</option>
            <option value="skeptical">Skeptical (Assume it's wrong, prove it's right)</option>
          </select>
        </div>

        <button id="generate-btn" class="action-btn">Generate Fact-Check Prompt</button>
      </div>

      <!-- Output Section -->
      <div class="checker-panel output-panel">
        <div class="panel-header">
          <h2>2. Your Fact-Check Prompt</h2>
          <button id="copy-btn" class="copy-btn" disabled>Copy</button>
        </div>
        
        <!-- ARIA Live region -->
        <div aria-live="polite" class="sr-only" id="sr-announcer"></div>
        
        <div class="output-box" id="output-box">
          <span class="placeholder-text">Configure the audit on the left to generate your prompt...</span>
        </div>
        <p class="output-hint">Paste this back into your chat to force the AI to check its work.</p>
      </div>
    </div>

    <BridgeCTA 
      heading="Don't want to doubt your AI?"
      subtext="ThinkMode+ includes a Precision Toggle that automatically forces the AI to verify factual claims before stating them. Stop hallucination before it happens."
      link="/#features"
      btnText="Discover ThinkMode+"
    />
  </div>

  <style>
    .tool-page { max-width: 960px; margin: 0 auto; padding: 32px 24px 80px; }

    .checker-tool { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 64px; }
    @media (max-width: 768px) { .checker-tool { grid-template-columns: 1fr; } }

    .checker-panel { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 16px; padding: 24px; display: flex; flex-direction: column; }
    
    .panel-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 8px;}
    .panel-header h2 { font-size: 18px; font-weight: 600; margin: 0; }
    
    .ghost-btn { background: transparent; border: none; color: var(--text-dim); font-size: 13px; cursor: pointer; transition: color 0.2s; padding: 4px 8px; }
    .ghost-btn:hover { color: var(--accent-pink); }
    
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; font-size: 14px; font-weight: 600; margin-bottom: 8px; color: var(--text); }
    
    #claim-input { width: 100%; min-height: 120px; padding: 12px; background: var(--surface); border: 1px solid var(--border-hi); border-radius: 8px; color: var(--text); font-family: var(--display); font-size: 14px; resize: vertical; transition: border-color 0.3s, box-shadow 0.3s; }
    #claim-input:focus-visible { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px rgba(186, 58, 184, 0.2); }
    #claim-input.error { border-color: #ef4444; animation: shake 0.4s; }
    
    select { width: 100%; padding: 10px 12px; background: var(--surface); border: 1px solid var(--border-hi); border-radius: 8px; color: var(--text); font-size: 14px; transition: border-color 0.2s; }
    select:focus-visible { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px rgba(186, 58, 184, 0.2); }
    
    .action-btn { width: 100%; padding: 12px; background: var(--accent); color: #fff; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); margin-top: auto; }
    .action-btn:hover { background: #d040ce; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(186, 58, 184, 0.2); }
    .action-btn:active { transform: scale(0.98); }
    
    .output-box { flex: 1; background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 16px; font-family: var(--mono); font-size: 13px; color: var(--text); line-height: 1.6; white-space: pre-wrap; margin-bottom: 12px; min-height: 200px; transition: background-color 0.3s; }
    .output-box.updated { background-color: rgba(186, 58, 184, 0.1); }
    .placeholder-text { color: var(--text-faint); font-style: italic; }
    
    .output-hint { font-size: 13px; color: var(--text-dim); margin: 0; }
    
    .copy-btn { padding: 6px 16px; background: var(--surface-2); border: 1px solid var(--border-hi); border-radius: 6px; color: var(--text); font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
    .copy-btn:hover:not(:disabled) { background: var(--border); }
    .copy-btn:active:not(:disabled) { transform: scale(0.95); }
    .copy-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .copy-btn:focus-visible { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px rgba(186, 58, 184, 0.2); }
    .copy-btn.copied { color: #22c55e; border-color: rgba(34,197,94,0.4); }

    .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); border: 0; }

    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-5px); }
      75% { transform: translateX(5px); }
    }
  </style>

  <script>
    document.addEventListener('astro:page-load', () => {
      const generateBtn = document.getElementById('generate-btn');
      const claimInput = document.getElementById('claim-input');
      const strictnessSelect = document.getElementById('strictness-select');
      const outputBox = document.getElementById('output-box');
      const copyBtn = document.getElementById('copy-btn');
      const clearBtn = document.getElementById('clear-btn');
      const srAnnouncer = document.getElementById('sr-announcer');

      if (!generateBtn || !claimInput) return;

      // Restore session storage
      const savedClaim = sessionStorage.getItem('hc_claim_text');
      if (savedClaim) claimInput.value = savedClaim;
      claimInput.addEventListener('input', () => {
        claimInput.classList.remove('error');
        sessionStorage.setItem('hc_claim_text', claimInput.value);
      });

      clearBtn.addEventListener('click', () => {
        claimInput.value = '';
        sessionStorage.removeItem('hc_claim_text');
        outputBox.innerHTML = '<span class="placeholder-text">Configure the audit on the left to generate your prompt...</span>';
        copyBtn.disabled = true;
        claimInput.focus();
      });

      generateBtn.addEventListener('click', () => {
        const claim = claimInput.value.trim();
        
        if (!claim) {
          claimInput.classList.add('error');
          claimInput.focus();
          return;
        }

        const strictness = strictnessSelect.value;
        let instructions = '';
        if (strictness === 'moderate') {
          instructions = 'Please review the text below for any factual inaccuracies, logical inconsistencies, or hallucinations. If you find any errors, explicitly correct them.';
        } else if (strictness === 'strict') {
          instructions = 'Critically audit the text below for factual correctness. For every factual claim made, provide a reliable citation or source to back it up. If a claim cannot be verified, explicitly state that it is unverified or potentially a hallucination.';
        } else if (strictness === 'skeptical') {
          instructions = 'Assume the text below contains AI hallucinations and factual errors. Your task is to play devil\'s advocate and actively try to debunk the claims made. Only accept claims that are demonstrably true, and aggressively highlight any fabricated information.';
        }

        const promptText = `I want you to perform a self-reflection and fact-check on the following text.\n\n### Instructions\n${instructions}\n\n### Text to Audit\n"""\n${claim}\n"""`;

        outputBox.textContent = promptText;
        copyBtn.disabled = false;

        // Flash interaction
        outputBox.classList.add('updated');
        setTimeout(() => outputBox.classList.remove('updated'), 300);

        // Smart scroll mobile only
        if (window.innerWidth < 768) {
          const rect = outputBox.getBoundingClientRect();
          if (rect.bottom > window.innerHeight || rect.top < 0) {
            outputBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      });

      let copyTimerId = null;
      if (copyBtn) {
        copyBtn.addEventListener('click', async () => {
          if (copyBtn.disabled) return;
          try {
            await navigator.clipboard.writeText(outputBox.textContent);
            if (srAnnouncer) srAnnouncer.textContent = 'Prompt copied to clipboard';
            
            const orig = copyBtn.getAttribute('data-orig') || copyBtn.textContent;
            copyBtn.setAttribute('data-orig', orig);
            copyBtn.textContent = 'Copied!';
            copyBtn.classList.add('copied');
            
            if (copyTimerId) clearTimeout(copyTimerId);
            
            copyTimerId = setTimeout(() => {
              copyBtn.textContent = orig;
              copyBtn.classList.remove('copied');
              copyTimerId = null;
            }, 2000);
          } catch (err) {
            console.error('Copy failed');
          }
        });
      }
    });
  </script>
</BaseLayout>
