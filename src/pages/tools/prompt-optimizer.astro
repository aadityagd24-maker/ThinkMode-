---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolHero from '../../components/ToolHero.astro';
import BridgeCTA from '../../components/BridgeCTA.astro';
import RelatedTools from '../../components/RelatedTools.astro';
---

<BaseLayout
  title="Why is ChatGPT Giving Bad Answers? | Fix Bad Prompts Instantly"
  description="Is ChatGPT giving you bad, generic answers? Use our free Prompt Fixer to figure out why and automatically turn weak instructions into highly optimized prompts."
  canonicalPath="/tools/prompt-optimizer"
>
  <Fragment slot="head">
    <meta name="keywords" content="why is chatgpt giving bad answers, chatgpt bad prompt fixer, make my chatgpt prompt better, improve chatgpt prompt, chatgpt prompt improver, prompt engineering for beginners chatgpt">

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "ChatGPT Bad Prompt Fixer",
      "url": "https://thinkmodeplus.com/tools/prompt-optimizer",
      "description": "Diagnose why ChatGPT is giving bad answers and instantly optimize your prompts.",
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thinkmodeplus.com/" },
        { "@type": "ListItem", "position": 2, "name": "Tools", "item": "https://thinkmodeplus.com/tools" },
        { "@type": "ListItem", "position": 3, "name": "Bad Prompt Fixer", "item": "https://thinkmodeplus.com/tools/prompt-optimizer" }
      ]
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": "How to fix a bad ChatGPT prompt",
      "description": "Use the free Prompt Fixer to diagnose why ChatGPT is giving bad answers and inject roles, frameworks, and instructions into weak prompts.",
      "step": [
        { "@type": "HowToStep", "name": "Paste Weak Prompt", "text": "Paste the prompt that gave you a bad answer into the input box." },
        { "@type": "HowToStep", "name": "Select Fix Level", "text": "Choose between Minimal, Standard, or Deep Thinking fixes." },
        { "@type": "HowToStep", "name": "Generate & Copy", "text": "Click Fix Prompt and copy the enhanced version." }
      ]
    })} />
  </Fragment>

  <div class="tool-page">
    <ToolHero 
      title="Why is ChatGPT Giving Bad Answers?"
      subtitle="If ChatGPT is giving you lazy, generic responses, it's usually because your prompt lacks constraints. Paste your bad prompt below, and we'll fix it instantly."
      breadcrumbToolName="Bad Prompt Fixer"
      toolPath="/tools/prompt-optimizer"
    />

    <div class="optimizer-tool">
      <!-- Input Side -->
      <div class="panel input-panel">
        <div class="panel-header">
          <h2>Your Basic Prompt</h2>
          <button id="clear-btn" class="ghost-btn">Clear</button>
        </div>
        <textarea id="basic-prompt" placeholder="E.g., Write a blog post about marketing..."></textarea>
        
        <div class="controls">
          <div class="control-group">
            <label for="enhancement-level">Fix Level</label>
            <select id="enhancement-level">
              <option value="minimal">Minimal (Fix clarity & tone)</option>
              <option value="standard" selected>Standard (Add role & structure)</option>
              <option value="deep">Deep Thinking (Add logic frameworks)</option>
            </select>
          </div>
          <button id="optimize-btn" class="action-btn">Fix Prompt</button>
        </div>
      </div>

      <!-- Output Side -->
      <div class="panel output-panel">
        <div class="panel-header">
          <div class="output-title">
            <h2>Fixed Prompt</h2>
            <div id="detected-role" class="role-badge" style="display: none;"></div>
          </div>
          <button id="copy-btn" class="action-btn secondary" disabled>
            <svg id="copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
            <span id="copy-text">Copy</span>
          </button>
        </div>

        <div aria-live="polite" class="sr-only" id="sr-announcer"></div>

        <div class="output-box" id="output-box">
          <span class="placeholder-text">Enter your bad prompt on the left to see the fixed version here...</span>
        </div>

        <div class="enhancement-tags" id="enhancement-tags">
          <!-- Tags injected by JS -->
        </div>
      </div>
    </div>

    <BridgeCTA 
      heading="Stop fixing bad prompts manually."
      subtext="ThinkMode+ automatically forces ChatGPT, Claude, and Gemini into deep thinking mode on every single prompt you send. No more lazy, generic answers."
      link="/#features"
      btnText="Discover ThinkMode+"
    />
    
    <RelatedTools />
  </div>

  <style>
    .tool-page { max-width: 1000px; margin: 0 auto; padding: 32px 24px 80px; }

    .optimizer-tool { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 64px; }
    @media (max-width: 768px) { .optimizer-tool { grid-template-columns: 1fr; } }

    .panel { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 16px; padding: 24px; display: flex; flex-direction: column; }
    .panel-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; flex-wrap: wrap; gap: 8px;}
    .panel-header h2 { font-size: 18px; font-weight: 600; margin: 0; display: flex; align-items: center; gap: 8px; }
    
    .ghost-btn { background: transparent; border: none; color: var(--text-dim); font-size: 13px; cursor: pointer; transition: color 0.2s; padding: 4px 8px; }
    .ghost-btn:hover { color: var(--accent-pink); }
    
    #basic-prompt { width: 100%; min-height: 200px; padding: 16px; background: var(--surface); border: 1px solid var(--border); border-radius: 10px; color: var(--text); font-family: var(--display); font-size: 15px; line-height: 1.6; resize: vertical; margin-bottom: 24px; transition: border-color 0.3s, box-shadow 0.3s; }
    #basic-prompt:focus-visible { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px rgba(186, 58, 184, 0.2); }
    #basic-prompt.error { border-color: #ef4444; animation: shake 0.4s; }

    .controls { display: flex; flex-direction: column; gap: 16px; margin-top: auto; }
    .control-group label { display: block; font-size: 13px; font-weight: 600; color: var(--text-dim); margin-bottom: 6px; }
    select { width: 100%; padding: 10px 12px; background: var(--surface); border: 1px solid var(--border-hi); border-radius: 8px; color: var(--text); font-size: 14px; transition: border-color 0.2s; }
    select:focus-visible { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px rgba(186, 58, 184, 0.2); }

    .action-btn { display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 12px 24px; background: var(--accent); color: #fff; border: none; border-radius: 8px; font-weight: 600; font-size: 15px; cursor: pointer; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); }
    .action-btn:hover:not(:disabled) { background: #d040ce; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(186, 58, 184, 0.2); }
    .action-btn:active:not(:disabled) { transform: scale(0.98); }
    .action-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    
    .action-btn.secondary { background: var(--surface-2); border: 1px solid var(--border-hi); color: var(--text); padding: 8px 16px; font-size: 13px; }
    .action-btn.secondary:hover:not(:disabled) { background: var(--border); box-shadow: none; }
    .action-btn.secondary.copied { color: #22c55e; border-color: rgba(34,197,94,0.4); }

    .output-box { flex: 1; background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 16px; font-family: var(--mono); font-size: 14px; color: var(--text); line-height: 1.6; white-space: pre-wrap; margin-bottom: 16px; min-height: 250px; overflow-y: auto; transition: background-color 0.3s; }
    .output-box.updated { background-color: rgba(186, 58, 184, 0.1); }
    .placeholder-text { color: var(--text-faint); font-style: italic; }

    .role-badge { background: rgba(186, 58, 184, 0.15); color: var(--accent-pink); border: 1px solid rgba(186, 58, 184, 0.3); padding: 2px 8px; border-radius: 20px; font-size: 11px; font-weight: 600; font-family: var(--mono); text-transform: uppercase; letter-spacing: 0.5px; }
    .output-title { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }

    .enhancement-tags { display: flex; flex-wrap: wrap; gap: 8px; }
    :global(.e-tag) { font-size: 12px; padding: 4px 10px; background: rgba(255,255,255,0.05); border: 1px solid var(--border); border-radius: 6px; color: var(--text-dim); display: flex; align-items: center; gap: 4px; }
    :global(.e-tag.active) { color: var(--text); background: rgba(255,255,255,0.1); border-color: var(--border-hi); }
    :global(.e-tag svg) { width: 12px; height: 12px; color: #22c55e; flex-shrink: 0; }

    .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); border: 0; }

    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-5px); }
      75% { transform: translateX(5px); }
    }
  </style>

  <script>
    document.addEventListener('astro:page-load', () => {
      const basicInput = document.getElementById('basic-prompt');
      const levelSelect = document.getElementById('enhancement-level');
      const optimizeBtn = document.getElementById('optimize-btn');
      const outputBox = document.getElementById('output-box');
      const copyBtn = document.getElementById('copy-btn');
      const detectedRoleBadge = document.getElementById('detected-role');
      const tagsContainer = document.getElementById('enhancement-tags');
      const clearBtn = document.getElementById('clear-btn');
      const srAnnouncer = document.getElementById('sr-announcer');

      if (!basicInput || !optimizeBtn) return;

      const savedPrompt = sessionStorage.getItem('po_basic_prompt');
      if (savedPrompt) basicInput.value = savedPrompt;
      basicInput.addEventListener('input', () => {
        basicInput.classList.remove('error');
        sessionStorage.setItem('po_basic_prompt', basicInput.value);
      });

      clearBtn.addEventListener('click', () => {
        basicInput.value = '';
        sessionStorage.removeItem('po_basic_prompt');
        outputBox.innerHTML = '<span class="placeholder-text">Enter your bad prompt on the left to see the fixed version here...</span>';
        copyBtn.disabled = true;
        detectedRoleBadge.style.display = 'none';
        tagsContainer.innerHTML = '';
        basicInput.focus();
      });

      const roleKeywords = {
        'Software Engineer': ['code', 'script', 'debug', 'api', 'react', 'python', 'javascript', 'html', 'css', 'sql', 'database'],
        'Marketer': ['marketing', 'seo', 'blog', 'ad copy', 'campaign', 'social media', 'tweet', 'linkedin'],
        'Copywriter': ['write', 'essay', 'article', 'newsletter', 'email', 'rewrite', 'grammar'],
        'Data Analyst': ['data', 'excel', 'csv', 'analyze', 'statistics', 'chart', 'plot', 'pandas'],
        'Tutor': ['explain', 'learn', 'understand', 'concept', 'what is', 'how does', 'tutorial']
      };

      function detectRole(prompt) {
        const p = prompt.toLowerCase();
        for (const [role, keywords] of Object.entries(roleKeywords)) {
          if (keywords.some(kw => p.includes(kw))) return role;
        }
        return 'AI Assistant';
      }

      function updateTags(level, hasRole) {
        tagsContainer.innerHTML = '';
        const tags = [
          { id: 'clarity', label: 'Clarity & Formatting', active: true },
          { id: 'role', label: 'Expert Persona', active: level === 'standard' || level === 'deep' },
          { id: 'constraints', label: 'Strict Constraints', active: level === 'standard' || level === 'deep' },
          { id: 'logic', label: 'Chain of Thought', active: level === 'deep' },
          { id: 'edge', label: 'Edge Case Analysis', active: level === 'deep' }
        ];

        tags.forEach(tag => {
          const el = document.createElement('div');
          el.className = `e-tag ${tag.active ? 'active' : ''}`;
          el.innerHTML = tag.active 
            ? `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg> ${tag.label}`
            : tag.label;
          tagsContainer.appendChild(el);
        });
      }

      optimizeBtn.addEventListener('click', () => {
        const raw = basicInput.value.trim();
        if (!raw) {
          basicInput.classList.add('error');
          basicInput.focus();
          return;
        }

        const level = levelSelect.value;
        const role = detectRole(raw);
        
        let optimized = "";

        if (level === 'minimal') {
          optimized = `Please act as a helpful AI assistant and fulfill the following request clearly and concisely. Format the output with headers and bullet points where appropriate.\n\n### Request\n${raw}`;
        } 
        else if (level === 'standard') {
          optimized = `Act as an expert ${role}. I need you to complete a task for me. Follow these constraints strictly:\n- Provide a direct, highly-actionable response.\n- Do not include conversational filler ("Here is your answer").\n- Structure the output for maximum readability.\n\n### Task\n${raw}`;
        }
        else if (level === 'deep') {
          optimized = `Act as a senior ${role} with decades of experience. I have a complex task for you.\n\n### Task\n${raw}\n\n### Execution Framework\nBefore providing the final answer, please use a <thinking> block to map out your logic step-by-step. Consider:\n1. The core goal of the request.\n2. Potential edge cases or common pitfalls.\n3. The optimal structure for the final output.\n\nAfter your thinking process, provide the final answer under a "### Final Solution" header. Ensure the response is authoritative, highly structured, and skips all conversational pleasantries.`;
        }

        outputBox.textContent = optimized;
        copyBtn.disabled = false;
        
        detectedRoleBadge.textContent = role;
        detectedRoleBadge.style.display = 'block';
        
        updateTags(level, true);

        // Flash interaction
        outputBox.classList.add('updated');
        setTimeout(() => outputBox.classList.remove('updated'), 300);

        // Smart scroll mobile only
        if (window.innerWidth < 768) {
          const rect = outputBox.getBoundingClientRect();
          if (rect.bottom > window.innerHeight || rect.top < 0) {
            outputBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      });

      let copyTimerId = null;
      if (copyBtn) {
        copyBtn.addEventListener('click', async () => {
          if (copyBtn.disabled) return;
          try {
            await navigator.clipboard.writeText(outputBox.textContent);
            if (srAnnouncer) srAnnouncer.textContent = 'Optimized prompt copied to clipboard';
            
            const copyText = document.getElementById('copy-text');
            const orig = copyBtn.getAttribute('data-orig') || copyText.textContent;
            copyBtn.setAttribute('data-orig', orig);
            
            copyText.textContent = 'Copied!';
            copyBtn.classList.add('copied');
            
            if (copyTimerId) clearTimeout(copyTimerId);
            
            copyTimerId = setTimeout(() => {
              copyText.textContent = orig;
              copyBtn.classList.remove('copied');
              copyTimerId = null;
            }, 2000);
          } catch (err) {
            console.error('Copy failed');
          }
        });
      }
    });
  </script>
</BaseLayout>
