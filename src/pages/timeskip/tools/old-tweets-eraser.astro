---
import TimeSkipLayout from '../../../layouts/TimeSkipLayout.astro';

const title = "Old Tweets Eraser Assistant - Find Tweets by Era";
const description = "Find your embarrassing old tweets from high school or college. Select a date range to generate a link to all your old X/Twitter posts.";
const canonicalPath = "/tools/old-tweets-eraser";
---

<TimeSkipLayout title={title} description={description} canonicalPath={canonicalPath}>
  <Fragment slot="head">
    <style>
      .tool-page {
        background-color: #f9fafb;
        min-height: calc(100vh - 140px);
        padding: 80px 20px;
        font-family: 'Inter', sans-serif;
        color: #111827;
      }
      .tool-container {
        max-width: 600px;
        margin: 0 auto;
      }
      .tool-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 40px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
      }
      .tool-title {
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 12px;
        text-align: center;
        letter-spacing: -0.5px;
      }
      .tool-subtitle {
        font-size: 16px;
        color: #4b5563;
        margin-bottom: 32px;
        text-align: center;
        line-height: 1.5;
      }
      .input-group {
        margin-bottom: 20px;
      }
      .input-label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 8px;
      }
      .tool-input {
        width: 100%;
        background: #f3f4f6;
        border: 2px solid #e5e7eb;
        border-radius: 8px;
        padding: 12px 16px;
        font-size: 16px;
        color: #111827;
        outline: none;
        transition: border-color 0.2s, background 0.2s;
        box-sizing: border-box;
      }
      .tool-input:focus {
        border-color: #0f1419;
        background: #ffffff;
      }
      .flex-row {
        display: flex;
        gap: 16px;
      }
      .flex-row .input-group {
        flex: 1;
      }
      .tool-btn {
        display: block;
        width: 100%;
        background-color: #0f1419;
        color: #ffffff;
        border: none;
        border-radius: 8px;
        padding: 16px;
        font-size: 18px;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 0.2s;
        margin-top: 24px;
      }
      .tool-btn:hover {
        background-color: #272c30;
      }
      
      /* CTA Bridge */
      .bridge-cta {
        margin-top: 32px;
        padding: 24px;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }
      .bridge-content h3 {
        font-size: 16px;
        font-weight: 600;
        color: #1e3a8a;
        margin-bottom: 4px;
      }
      .bridge-content p {
        font-size: 14px;
        color: #1e40af;
        margin: 0;
      }
      .bridge-btn {
        background: #2563eb;
        color: white;
        padding: 10px 20px;
        border-radius: 6px;
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
        white-space: nowrap;
      }
      .bridge-btn:hover {
        background: #1d4ed8;
      }

      /* SEO Content */
      .seo-content {
        margin-top: 64px;
        padding-top: 48px;
        border-top: 1px solid #e5e7eb;
      }
      .seo-content h2 {
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 16px;
        margin-top: 32px;
        color: #111827;
      }
      .seo-content p {
        font-size: 16px;
        line-height: 1.7;
        color: #4b5563;
        margin-bottom: 16px;
      }

      @media (max-width: 640px) {
        .tool-card {
          padding: 24px;
        }
        .flex-row {
          flex-direction: column;
          gap: 0;
        }
        .bridge-cta {
          flex-direction: column;
          text-align: center;
        }
        .bridge-btn {
          width: 100%;
          text-align: center;
        }
      }
    </style>
  </Fragment>

  <main class="tool-page">
    <div class="tool-container">
      
      <div class="tool-card">
        <h1 class="tool-title">Old Tweets Eraser Assistant</h1>
        <p class="tool-subtitle">Find your old tweets from a specific era (like high school) so you can review and delete them.</p>
        
        <form id="searchForm">
          <div class="input-group">
            <label class="input-label" for="username">Your Twitter Handle</label>
            <input type="text" id="username" class="tool-input" placeholder="e.g. your_handle" required />
          </div>
          
          <div class="flex-row">
            <div class="input-group">
              <label class="input-label" for="startYear">Start Year</label>
              <input type="number" id="startYear" class="tool-input" placeholder="e.g. 2010" min="2006" max="2025" required />
            </div>
            <div class="input-group">
              <label class="input-label" for="endYear">End Year</label>
              <input type="number" id="endYear" class="tool-input" placeholder="e.g. 2014" min="2006" max="2025" required />
            </div>
          </div>
          
          <button type="submit" class="tool-btn" id="submitBtn">
            Find Old Tweets
          </button>
        </form>

        <div class="bridge-cta">
          <div class="bridge-content">
            <h3>Checking how favorite creators started?</h3>
            <p>TimeSkip lets you view anyone's timeline month-by-month to see their growth.</p>
          </div>
          <a href="/timeskip/#pricing" class="bridge-btn">Get Extension</a>
        </div>
      </div>

      <article class="seo-content">
        <h2>How to find and delete old tweets</h2>
        <p>We all tweeted things in high school or college that we probably shouldn't have. If you are applying for a job, building a personal brand, or just doing some spring cleaning, finding those old tweets is the first step to deleting them.</p>
        <p>This tool creates a targeted search query for your account within a specific range of years. Once the link opens in X, you can review the results and delete any tweets directly from the X interface.</p>
        
        <h2>Why use TimeSkip?</h2>
        <p>If you're fascinated by Twitter history and love seeing how big creators or brands started out, you need <strong>TimeSkip</strong>. It's a Chrome extension that turns any X profile into a time machine, allowing you to instantly jump to any year and month with just one click.</p>
      </article>

    </div>
  </main>

  <Fragment slot="scripts">
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('searchForm');
        const submitBtn = document.getElementById('submitBtn');

        form.addEventListener('submit', (e) => {
          e.preventDefault();
          
          const username = document.getElementById('username').value.trim().replace(/^@/, '');
          const startYear = document.getElementById('startYear').value;
          const endYear = document.getElementById('endYear').value;

          if (!username || !startYear || !endYear) return;

          const query = \`from:\${username} since:\${startYear}-01-01 until:\${parseInt(endYear)+1}-01-01\`;
          const xUrl = \`https://x.com/search?q=\${encodeURIComponent(query)}&src=typed_query&f=live\`;
          
          submitBtn.textContent = 'Redirecting to X...';
          submitBtn.style.opacity = '0.8';

          setTimeout(() => {
            window.open(xUrl, '_blank');
            submitBtn.textContent = 'Find Old Tweets';
            submitBtn.style.opacity = '1';
          }, 600);
        });
      });
    </script>
  </Fragment>
</TimeSkipLayout>
