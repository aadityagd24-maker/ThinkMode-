---
import TimeSkipLayout from '../../../layouts/TimeSkipLayout.astro';
import '../../../styles/tools.css';

const title = "Twitter Relationship Explorer - Find Interactions Between Users";
const description = "Discover old conversations and interactions between two specific X (Twitter) accounts quickly and easily.";
const canonicalPath = "/timeskip/tools/relationship-explorer";
---

<TimeSkipLayout title={title} description={description} canonicalPath={canonicalPath}>
  <main class="tool-page">
    <div class="tool-container">
      
      <a href="/timeskip/tools" class="back-link">← Back to all free tools</a>

      <div class="tool-card">
        <h1 class="tool-title">Twitter Relationship Explorer</h1>
        <p class="tool-subtitle">Find conversations and replies between two specific X accounts.</p>
        
        <form id="searchForm">
          <div class="input-group">
            <label class="input-label" for="userA">User A Handle</label>
            <input type="text" id="userA" class="tool-input" placeholder="e.g. stevejobs" required />
          </div>
          
          <div class="input-group">
            <label class="input-label" for="userB">User B Handle</label>
            <input type="text" id="userB" class="tool-input" placeholder="e.g. billgates" required />
          </div>
          
          <button type="submit" class="tool-btn" id="submitBtn">
            Find Interactions
          </button>
        </form>

        <div class="bridge-cta">
          <div class="bridge-content">
            <h3>Doing deep-dive research?</h3>
            <p>TimeSkip lets you view any account's historical timeline month-by-month.</p>
          </div>
          <a href="/timeskip/#pricing" class="bridge-btn">Get Extension</a>
        </div>
      </div>

      <article class="seo-content">
        <h2>How to find interactions between two Twitter users</h2>
        <p>Curious if two founders ever talked to each other back in the day? Want to see how a brand interacted with a specific influencer? Finding these conversations manually is like looking for a needle in a haystack.</p>
        <p>Our tool generates a bi-directional search query (<code>from:UserA to:UserB OR from:UserB to:UserA</code>) to instantly pull up all public mentions and replies between those exact accounts.</p>
        
        <h2>Speed up your Twitter Research</h2>
        <p>If you're a journalist, researcher, or social media manager digging through Twitter history, <strong>TimeSkip</strong> is the ultimate tool. It seamlessly integrates into X.com and lets you jump to any month or year on any profile without needing to remember complex search operators.</p>
      </article>

    </div>
  </main>

  <Fragment slot="scripts">
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('searchForm');
        const submitBtn = document.getElementById('submitBtn');

        form.addEventListener('submit', (e) => {
          e.preventDefault();
          
          const userA = document.getElementById('userA').value.trim().replace(/^@/, '');
          const userB = document.getElementById('userB').value.trim().replace(/^@/, '');

          if (!userA || !userB) return;

          const query = `(from:${userA} to:${userB}) OR (from:${userB} to:${userA})`;
          const xUrl = `https://x.com/search?q=${encodeURIComponent(query)}&src=typed_query&f=live`;
          
          submitBtn.textContent = 'Redirecting to X...';
          submitBtn.style.opacity = '0.8';

          setTimeout(() => {
            window.open(xUrl, '_blank');
            submitBtn.textContent = 'Find Interactions';
            submitBtn.style.opacity = '1';
          }, 600);
        });
      });
    </script>
  </Fragment>
</TimeSkipLayout>

