---
import TimeSkipLayout from '../../../layouts/TimeSkipLayout.astro';

const title = "Free X (Twitter) Search Tools - TimeSkip";
const description = "A collection of free utility tools to search old tweets, find deleted interactions, and master Twitter Advanced Search.";
const canonicalPath = "/timeskip/tools";

const tools = [
  {
    title: "First Tweet Finder",
    description: "Instantly find the oldest tweets of any public X/Twitter account. No login required.",
    href: "/timeskip/tools/first-tweet-finder",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #3b82f6;"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><path d="M11 8v3l2 2"></path></svg>`
  },
  {
    title: "Advanced Search Generator",
    description: "Generate complex X (Twitter) search queries instantly without memorizing operators.",
    href: "/timeskip/tools/advanced-search",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #8b5cf6;"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>`
  },
  {
    title: "On This Day Tweet Finder",
    description: "Find what any user tweeted on a specific date in history.",
    href: "/timeskip/tools/on-this-day",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #ec4899;"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>`
  },
  {
    title: "Relationship Explorer",
    description: "Find conversations and replies between two specific X accounts.",
    href: "/timeskip/tools/relationship-explorer",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #10b981;"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>`
  },
  {
    title: "Old Tweets Eraser Assistant",
    description: "Find your old tweets from a specific era so you can review and delete them.",
    href: "/timeskip/tools/old-tweets-eraser",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #ef4444;"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>`
  }
];
---

<TimeSkipLayout title={title} description={description} canonicalPath={canonicalPath}>
  <Fragment slot="head">
    <style>
      .tools-index {
        background-color: #f9fafb;
        min-height: calc(100vh - 140px);
        padding: 80px 20px;
        font-family: 'Inter', sans-serif;
        color: #111827;
      }
      .container {
        max-width: 800px;
        margin: 0 auto;
      }
      .header-section {
        text-align: center;
        margin-bottom: 56px;
      }
      .title {
        font-size: 36px;
        font-weight: 800;
        letter-spacing: -1px;
        margin-bottom: 16px;
      }
      .subtitle {
        font-size: 18px;
        color: #4b5563;
        max-width: 600px;
        margin: 0 auto;
        line-height: 1.6;
      }
      .tools-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 24px;
      }
      .tool-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 32px 24px;
        text-decoration: none;
        color: inherit;
        transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
        display: flex;
        flex-direction: column;
      }
      .tool-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        border-color: #d1d5db;
      }
      .tool-icon {
        margin-bottom: 16px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        border-radius: 10px;
        background-color: #f3f4f6;
      }
      .tool-name {
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 12px;
        color: #111827;
      }
      .tool-desc {
        font-size: 15px;
        color: #6b7280;
        line-height: 1.5;
        flex-grow: 1;
      }
      .bridge-cta {
        margin-top: 64px;
        padding: 32px;
        background: #0f1419;
        border-radius: 12px;
        text-align: center;
        color: white;
      }
      .bridge-cta h3 {
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 12px;
      }
      .bridge-cta p {
        font-size: 16px;
        color: #9ca3af;
        margin-bottom: 24px;
        max-width: 500px;
        margin-left: auto;
        margin-right: auto;
      }
      .bridge-btn {
        display: inline-block;
        background: #ffffff;
        color: #0f1419;
        padding: 14px 28px;
        border-radius: 8px;
        text-decoration: none;
        font-size: 16px;
        font-weight: 600;
        transition: background 0.2s;
      }
      .bridge-btn:hover {
        background: #f3f4f6;
      }
    </style>
  </Fragment>

  <main class="tools-index">
    <div class="container">
      <div class="header-section">
        <h1 class="title">Free X (Twitter) Search Tools</h1>
        <p class="subtitle">A collection of free utilities designed to help you search, explore, and find historical tweets effortlessly.</p>
      </div>

      <div class="tools-grid">
        {tools.map(tool => (
          <a href={tool.href} class="tool-card">
            <div class="tool-icon" set:html={tool.icon}></div>
            <h2 class="tool-name">{tool.title}</h2>
            <p class="tool-desc">{tool.description}</p>
          </a>
        ))}
      </div>

      <div class="bridge-cta">
        <h3>Want all of this directly on X.com?</h3>
        <p>TimeSkip is a Chrome extension that turns every Twitter profile into a time machine. Jump to any month or year in one click.</p>
        <a href="/timeskip/#pricing" class="bridge-btn">Get TimeSkip Now</a>
      </div>
    </div>
  </main>
</TimeSkipLayout>
