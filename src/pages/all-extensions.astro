---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="All Extensions - ThinkMode+" description="View all premium browser extensions by Aayush.">
  <div class="extensions-container wrap">
    <div class="sidebar">
      <div class="sidebar-header">
        <div class="sidebar-logo">
          <div class="mark"><img src="/logo.png" alt="Icon" /></div>
          <div>
            <h3>My Extensions</h3>
            <p>The Suite</p>
          </div>
        </div>
      </div>
      
      <div class="sidebar-menu">
        <div class="menu-item active">
          <div class="item-icon"><img src="/logo.png" alt="ThinkMode+" /></div>
          <div class="item-text">ThinkMode+</div>
          <div class="item-badges">
            <span class="badge feature-badge">FEATURED</span>
            <img src="/chrome-icon.svg" alt="Chrome" class="browser-icon" />
          </div>
        </div>

        <div class="menu-item">
          <div class="item-icon" style="background: #2a2a35; border-radius: 8px; padding: 4px;"><img src="/timeskip-logo.png" alt="TimeSkip" style="width:100%; height:100%; object-fit:contain;"/></div>
          <div class="item-text">TimeSkip</div>
          <div class="item-badges">
            <span class="badge version-badge">V1.0</span>
            <img src="/chrome-icon.svg" alt="Chrome" class="browser-icon" />
          </div>
        </div>
      </div>

      <div class="sidebar-footer">
        <span class="copyright">&copy; 2026 ThinkMode</span>
        <a href="/contact" class="contact-link">Contact</a>
      </div>
    </div>

    <div class="main-content">
      <!-- ThinkMode+ Content -->
      <div class="extension-view active" id="view-thinkmode">
        <div class="hero-card" style="background: linear-gradient(135deg, rgba(186, 58, 184, 0.2) 0%, rgba(90, 10, 120, 0.2) 100%);">
          <div class="platform-tags">
            <span class="platform-tag">ChatGPT</span>
            <span class="platform-tag">Claude</span>
            <span class="platform-tag">Gemini</span>
          </div>
          
          <div class="hero-body">
            <div class="hero-icon">
              <img src="/logo.png" alt="ThinkMode+" />
            </div>
            <div class="hero-text">
              <h1>ThinkMode+</h1>
              <p>Supercharge your AI with always-on extended thinking.</p>
            </div>
          </div>
          
          <div class="available-on">
            <span>AVAILABLE ON:</span>
            <div class="browser-icons-large">
              <img src="/chrome-icon.svg" alt="Chrome" />
              <img src="/edge-icon.svg" alt="Edge" />
            </div>
          </div>

          <div class="hero-actions">
            <a href="/" class="btn-visit">Visit Website &rarr;</a>
            <a href="https://chromewebstore.google.com/detail/thinkmode+/gdaonnlalhpjhddfpbfdkhjhinbideni" target="_blank" class="btn-store">
              <img src="/chrome-icon.svg" alt="Chrome" /> Chrome Store
            </a>
          </div>
        </div>

        <div class="info-cards">
          <div class="info-card">
            <div class="info-icon" style="background: rgba(186, 58, 184, 0.1); color: var(--accent);">⚡</div>
            <h3>Always-On Think Mode</h3>
            <p>Force AI to think deeply before answering. Get professional-grade outputs every time without prompt edits.</p>
          </div>
          <div class="info-card">
            <div class="info-icon" style="background: rgba(186, 58, 184, 0.1); color: var(--accent);">🎁</div>
            <h3>Generous Free Tier</h3>
            <p>Try the core loop for free with daily limits. Upgrade to unlock unlimited potential on 3 platforms.</p>
          </div>
        </div>
      </div>

      <!-- TimeSkip Content -->
      <div class="extension-view" id="view-timeskip" style="display: none;">
        <div class="hero-card" style="background: linear-gradient(135deg, rgba(29, 155, 240, 0.1) 0%, rgba(15, 20, 25, 0.8) 100%); border-color: rgba(29, 155, 240, 0.3);">
          <div class="platform-tags">
            <span class="platform-tag" style="background: rgba(29, 155, 240, 0.2); color: #1d9bf0;">X / Twitter</span>
          </div>
          
          <div class="hero-body">
            <div class="hero-icon" style="background: #0f1419; display: flex; align-items: center; justify-content: center;">
              <img src="/timeskip-logo.png" alt="TimeSkip" style="border-radius:12px; width:100%; height:100%; object-fit:contain;" />
            </div>
            <div class="hero-text">
              <h1>TimeSkip</h1>
              <p>Jump to any date on any X/Twitter profile. See someone's first tweets, browse by year or month — one click.</p>
            </div>
          </div>
          
          <div class="available-on">
            <span>AVAILABLE ON:</span>
            <div class="browser-icons-large">
              <img src="/chrome-icon.svg" alt="Chrome" />
              <img src="/edge-icon.svg" alt="Edge" />
            </div>
          </div>

          <div class="hero-actions">
            <a href="https://thinkmodeplus.com/timeskip" target="_blank" class="btn-visit">Visit Website &rarr;</a>
            <a href="https://chromewebstore.google.com/detail/timeskip-%E2%80%94-jump-to-any-da/mdhbogffjgljjefmiggmofgoiehilibl" target="_blank" class="btn-store">
              <img src="/chrome-icon.svg" alt="Chrome" /> Chrome Store
            </a>
          </div>
        </div>

        <div class="info-cards">
          <div class="info-card">
            <div class="info-icon" style="background: rgba(29, 155, 240, 0.1); color: #1d9bf0;">🕒</div>
            <h3>Time Travel</h3>
            <p>Instantly jump to a specific year and month on any user's profile. Find those old golden tweets.</p>
          </div>
          <div class="info-card">
            <div class="info-icon" style="background: rgba(29, 155, 240, 0.1); color: #1d9bf0;">🔍</div>
            <h3>Advanced Search</h3>
            <p>Seamlessly integrated with X's native search UI. One-click access to advanced filters.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    .extensions-container {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 32px;
      padding: 40px 32px;
      min-height: calc(100vh - 100px);
      align-items: start;
    }

    /* Sidebar */
    .sidebar {
      background: rgba(18, 18, 24, 0.4);
      border: 1px solid var(--border);
      border-radius: 16px;
      display: flex;
      flex-direction: column;
      height: 100%;
      min-height: 600px;
      position: sticky;
      top: 100px;
    }

    .sidebar-header {
      padding: 24px;
      border-bottom: 1px solid var(--border);
    }

    .sidebar-logo {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    
    .sidebar-logo .mark {
      width: 40px; height: 40px;
      background: #fff;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
    }
    
    .sidebar-logo .mark img {
      width: 24px; height: 24px;
      object-fit: contain;
    }

    .sidebar-logo h3 {
      font-size: 16px;
      margin: 0 0 2px;
      color: #fff;
    }
    .sidebar-logo p {
      font-size: 12px;
      color: var(--text-dim);
      margin: 0;
      font-family: var(--mono);
    }

    .sidebar-menu {
      padding: 16px;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .menu-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px;
      border-radius: 12px;
      cursor: pointer;
      transition: all 0.2s;
      border: 1px solid transparent;
    }

    .menu-item:hover {
      background: rgba(255,255,255,0.03);
    }

    .menu-item.active {
      background: rgba(186, 58, 184, 0.08);
      border-color: rgba(186, 58, 184, 0.2);
      box-shadow: 0 0 15px rgba(186, 58, 184, 0.1);
    }

    .item-icon {
      width: 32px; height: 32px;
      display: flex; align-items: center; justify-content: center;
    }
    .item-icon img { width: 100%; height: 100%; object-fit: contain; }
    
    .item-text {
      flex: 1;
      font-weight: 600;
      font-size: 14px;
    }

    .item-badges {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .badge {
      font-size: 10px;
      font-weight: 700;
      padding: 4px 8px;
      border-radius: 4px;
      letter-spacing: 0.5px;
    }
    .feature-badge {
      background: rgba(186, 58, 184, 0.2);
      color: #fff;
    }
    .version-badge {
      background: rgba(255,255,255,0.1);
      color: var(--text-dim);
    }

    .browser-icon {
      width: 16px; height: 16px;
      opacity: 0.8;
    }

    .sidebar-footer {
      padding: 16px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 12px;
      color: var(--text-faint);
      border-top: 1px solid var(--border);
    }

    .contact-link {
      color: var(--text-dim);
      transition: color 0.2s;
    }
    .contact-link:hover { color: #fff; }

    /* Main Content */
    .hero-card {
      border-radius: 24px;
      padding: 48px;
      text-align: center;
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(186, 58, 184, 0.3);
    }

    .platform-tags {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-bottom: 32px;
    }

    .platform-tag {
      background: rgba(255,255,255,0.1);
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
    }

    .hero-body {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 24px;
      margin-bottom: 40px;
    }

    .hero-icon {
      width: 80px; height: 80px;
      background: rgba(0,0,0,0.2);
      border-radius: 20px;
      padding: 16px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
    .hero-icon img { width: 100%; height: 100%; object-fit: contain; }

    .hero-text h1 {
      font-size: 48px;
      font-weight: 700;
      margin: 0 0 12px;
      letter-spacing: -0.02em;
    }
    .hero-text p {
      font-size: 18px;
      color: rgba(255,255,255,0.8);
      max-width: 500px;
      margin: 0 auto;
    }

    .available-on {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      margin-bottom: 40px;
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
    }

    .browser-icons-large {
      display: flex;
      gap: 12px;
      background: rgba(0,0,0,0.2);
      padding: 8px 16px;
      border-radius: 12px;
    }
    .browser-icons-large img {
      width: 24px; height: 24px;
    }

    .hero-actions {
      display: flex;
      justify-content: center;
      gap: 16px;
    }

    .btn-visit {
      background: rgba(255,255,255,0.1);
      color: #fff;
      padding: 12px 24px;
      border-radius: 12px;
      font-weight: 600;
      text-decoration: none;
      transition: background 0.2s;
    }
    .btn-visit:hover { background: rgba(255,255,255,0.2); }

    .btn-store {
      background: #fff;
      color: #000;
      padding: 12px 24px;
      border-radius: 12px;
      font-weight: 700;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: transform 0.2s;
    }
    .btn-store:hover { transform: translateY(-2px); }
    .btn-store img { width: 20px; height: 20px; }

    .info-cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      margin-top: 24px;
    }

    .info-card {
      background: rgba(18, 18, 24, 0.4);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 24px;
    }

    .info-icon {
      width: 40px; height: 40px;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px;
      margin-bottom: 16px;
    }

    .info-card h3 {
      font-size: 18px;
      margin: 0 0 8px;
    }
    .info-card p {
      font-size: 14px;
      color: var(--text-dim);
      margin: 0;
      line-height: 1.5;
    }

    @media (max-width: 900px) {
      .extensions-container {
        grid-template-columns: 1fr;
      }
      .sidebar {
        min-height: auto;
        position: static;
      }
      .info-cards {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    document.addEventListener('astro:page-load', () => {
      const menuItems = document.querySelectorAll('.menu-item');
      const views = document.querySelectorAll('.extension-view');

      menuItems.forEach((item, index) => {
        item.addEventListener('click', () => {
          // Remove active from all
          menuItems.forEach(i => i.classList.remove('active'));
          views.forEach(v => {
            v.classList.remove('active');
            v.style.display = 'none';
          });

          // Add active to clicked
          item.classList.add('active');
          if (views[index]) {
            views[index].classList.add('active');
            views[index].style.display = 'block';
          }
        });
      });
    });
  </script>
</BaseLayout>
