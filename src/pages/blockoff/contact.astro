---
import BlockOffLayout from '../../layouts/BlockOffLayout.astro';
---

<BlockOffLayout
  title="Contact Us | Block OFF"
  description="Contact Block OFF for early access, support, partnerships, press, or questions about AI comment moderation."
  canonicalPath="/blockoff/contact"
>
  <header class="site-header page-header">
    <a class="brand" href="/blockoff" aria-label="Block OFF home"><img src="/blockoff/block-off-logo.png" alt="" /><span>Block OFF</span></a>
    <nav class="main-nav" aria-label="Primary navigation"><a href="/blockoff/#product">Product</a><a href="/blockoff/#how">How it works</a><a href="/blockoff/#dashboard">Dashboard</a><a href="/blockoff/#pricing">Pricing</a></nav>
    <a class="header-cta" href="/blockoff/#waitlist">Join waitlist</a>
  </header>
  <main>
    <section class="page-hero"><span class="section-kicker">Contact</span><h1>Talk to us before the comments get loud.</h1><p>Use these contact paths for early access, support, partnerships, creator feedback, and product questions.</p></section>
    <section class="legal-layout">
      <nav class="legal-nav" aria-label="Contact sections"><a href="#general">General</a><a href="#support">Support</a><a href="#partners">Partners</a><a href="#feedback">Feedback</a></nav>
      <div class="contact-grid">
        <article class="contact-card" id="general"><h2>General</h2><p>For launch access, account questions, or product interest, email <a href="mailto:hello@blockoff.app">hello@blockoff.app</a>.</p></article>
        <article class="contact-card" id="support"><h2>Support</h2><p>For help with connected accounts, moderation settings, or early access issues, email <a href="mailto:support@blockoff.app">support@blockoff.app</a>.</p></article>
        <article class="contact-card" id="partners"><h2>Partnerships</h2><p>For agencies, creator communities, affiliates, and launch partners, email <a href="mailto:partners@blockoff.app">partners@blockoff.app</a>.</p></article>
        <article class="contact-card" id="feedback"><h2>Creator feedback</h2><p>If you manage YouTube or Instagram comments today, tell us what hurts most. Your workflow can shape the MVP.</p></article>
      </div>
    </section>
  </main>
  <footer class="site-footer">
    <a class="brand footer-brand" href="/blockoff" aria-label="Block OFF home"><img src="/blockoff/block-off-logo.png" alt="" /><span>Block OFF</span></a>
    <nav aria-label="Footer navigation"><a href="/blockoff/privacy">Privacy Policy</a><a href="/blockoff/terms">Terms & Conditions</a><a href="/blockoff/about">About Us</a><a href="/blockoff/contact">Contact Us</a><a href="/blockoff/support">Support</a><a href="/blockoff/changelog">Changelog</a></nav>
  </footer>
</BlockOffLayout>
